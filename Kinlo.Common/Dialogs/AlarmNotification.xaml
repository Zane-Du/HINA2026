<Border
    x:Class="Kinlo.Common.Dialogs.AlarmNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.Common.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    MinHeight="200"
    MaxWidth="1200"
    MaxHeight="800"
    Margin="30"
    Padding="32"
    d:DesignHeight="480"
    d:DesignWidth="880"
    Background="{DynamicResource RegionBrush}"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="0"
    CornerRadius="16"
    mc:Ignorable="d"
>
    <Border.Effect>
        <DropShadowEffect BlurRadius="35" Direction="-90" Opacity="0.5" ShadowDepth="10" Color="Gray" />
    </Border.Effect>
    <hc:SimplePanel>
        <TextBlock
            x:Name="TitleTxt"
            Margin="-10,-15,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            d:Text="警告:"
            Style="{StaticResource TextBlockTitleBold}"
            Text="{Binding Title}"
        />
        <TextBlock
            x:Name="ContentTxt"
            d:Text="你掉线啦!!!"
            Foreground="Red"
            Style="{StaticResource TextBlockSubTitleBold}"
            Text="{Binding Message}"
            TextWrapping="Wrap"
        />
        <Button
            Width="22"
            Height="22"
            Margin="0,-25,-25,0"
            Padding="0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            hc:IconElement.Geometry="{StaticResource ErrorGeometry}"
            Command="hc:ControlCommands.CloseWindow"
            CommandParameter="{Binding RelativeSource={RelativeSource Self}}"
            Foreground="{DynamicResource PrimaryBrush}"
            Style="{StaticResource ButtonIcon}"
        />
    </hc:SimplePanel>
</Border>
