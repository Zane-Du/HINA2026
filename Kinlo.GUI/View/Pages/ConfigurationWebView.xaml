<UserControl
    x:Class="Kinlo.GUI.View.ConfigurationWebView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    d:DataContext="{d:DesignInstance vm:ConfigurationWebViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource TitleSpace}" />
            <RowDefinition Height="{StaticResource MainSpace}" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Border
            Grid.ColumnSpan="5"
            Padding="{StaticResource TitlePadding1}"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="{DynamicResource MainCornerRadius}"
        >
            <Grid>
                <TextBlock
                    Margin="0,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{DynamicResource TextBlockTitleBold}"
                    Text="WebApi服务配置"
                />
                <StackPanel Margin="0,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button
                        Width="100"
                        Height="30"
                        Margin="0,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{s:Action StartWebCmd}"
                        Style="{StaticResource ButtonSuccess}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe622;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="启动服务" />
                        </StackPanel>
                    </Button>
                    <Button
                        Width="100"
                        Height="30"
                        Margin="10,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{s:Action StopWebCmd}"
                        Style="{StaticResource ButtonDanger}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe639;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="停止服务" />
                        </StackPanel>
                    </Button>
                    <Button
                        Width="100"
                        Height="30"
                        Margin="0,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{s:Action SaveCmd}"
                        Style="{StaticResource ButtonInfo}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe61b;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="{DynamicResource 保存}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="{StaticResource MainSpace}" />
                <ColumnDefinition Width="600" />
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />
            <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0" />
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <hc:TextBox
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            hc:TitleElement.Title="监听IP（ * 为监听全部网口）"
                            Text="{Binding WebApiCpoy.ListeningIP}"
                        />

                        <hc:TextBox
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Stretch"
                            hc:TitleElement.Title="端口"
                            Text="{Binding WebApiCpoy.Port}"
                        />
                        <CheckBox
                            Grid.Column="4"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Content="自动启动"
                            IsChecked="{Binding WebApiCpoy.AutoStartWebApi}"
                        />
                        <CheckBox
                            Grid.Column="6"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Content="启用在线调试（Swagger）"
                            IsChecked="{Binding WebApiCpoy.IsEnableSwagger}"
                        />
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="7" Margin="0,15,0,-5" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="4 0 0 4"
                                kc:LanguageResource.Key="全选"
                                Command="{s:Action SelectAllCmd}"
                                Style="{StaticResource ButtonPrimary}"
                            />
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="0"
                                kc:LanguageResource.Key="全不选"
                                Command="{s:Action DeselectAllCmd}"
                                Style="{StaticResource ButtonDanger}"
                            />
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="0 4 4 0"
                                kc:LanguageResource.Key="反选"
                                Command="{s:Action InvertSelectionCmd}"
                                Style="{StaticResource ButtonInfo}"
                            />
                        </StackPanel>
                    </Grid>

                    <DataGrid
                        Grid.Row="2"
                        Margin="0,0,0,0"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CellStyle="{DynamicResource OtherDisplayDataGridCellStyle}"
                        ItemsSource="{Binding WebApiCpoy.WebApiRoutes}"
                        RowHeight="35"
                        RowStyle="{StaticResource OtherDisplayDataGridRowStyle}"
                        SelectionUnit="Cell"
                    >
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock
                                        Margin="-10,0,0,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="{DynamicResource 启用}"
                                    />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="auto" MinWidth="300">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="{DynamicResource 接口}" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="{tools:ResourceBinding InterfaceName}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="路由" FontSize="14" FontWeight="Bold" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Margin="0,0,0,0"
                                            hc:BorderElement.CornerRadius="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.RowSpan="5" Grid.Column="2" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <!--<Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Style="{DynamicResource TextBlockSubTitleBold}"
                        Text="{DynamicResource 测试接口}" />
                    <hc:TextBox
                        Grid.Row="1"
                        Padding="3,0,25,0"
                        VerticalAlignment="Bottom"
                        hc:BorderElement.CornerRadius="0"
                        hc:TitleElement.Title="{DynamicResource MES接口}"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        BorderThickness="0,0,0,1"
                        IsReadOnly="True"
                        Text="{Binding InterfaceName}" />
                    <hc:TextBox
                        Grid.Row="2"
                        VerticalAlignment="Bottom"
                        hc:BorderElement.CornerRadius="0"
                        hc:TitleElement.Title="UrlOrTopic"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        BorderThickness="0,0,0,1"
                        IsReadOnly="True"
                        Text="{Binding Url}" />
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <hc:TextBox
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            hc:BorderElement.CornerRadius="0"
                            hc:TitleElement.Title="Test user"
                            hc:TitleElement.TitlePlacement="Left"
                            hc:TitleElement.TitleWidth="80"
                            BorderThickness="0,0,0,1"
                            IsReadOnly="False"
                            Text="{Binding TestUser}" />
                        <Button
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Command="{s:Action SendMes}"
                            Content="{DynamicResource 发送}"
                            Style="{StaticResource ButtonPrimary}" />
                    </Grid>
                    <hc:TextBox
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Margin="0,30,0,0"
                        Padding="10"
                        VerticalContentAlignment="Top"
                        hc:TitleElement.Title="{DynamicResource 发送数据(JSON):}"
                        hc:TitleElement.TitlePlacement="Top"
                        AcceptsReturn="True"
                        Text="{Binding SendTxt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                    <hc:TextBox
                        Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Margin="0,20,0,0"
                        Padding="10"
                        VerticalContentAlignment="Top"
                        hc:TitleElement.Title="{DynamicResource 返回数据:}"
                        hc:TitleElement.TitlePlacement="Top"
                        AcceptsReturn="True"
                        Text="{Binding ReceiveTxt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap" />
                </Grid>-->
            </Border>
        </Grid>
    </Grid>
</UserControl>
