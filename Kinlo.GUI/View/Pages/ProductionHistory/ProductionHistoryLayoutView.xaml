<UserControl
  x:Class="Kinlo.GUI.View.ProductionHistoryLayoutView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:hc="https://handyorg.github.io/handycontrol"
  xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
  xmlns:local="clr-namespace:Kinlo.GUI.View"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:s="https://github.com/canton7/Stylet"
  xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
  xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
  d:DataContext="{d:DesignInstance vm:ProductionHistoryLayoutViewModel}"
  d:DesignHeight="450"
  d:DesignWidth="800"
  hc:Dialog.Token="{Binding DialogToke}"
  mc:Ignorable="d">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="{StaticResource TitleSpace}" />
      <RowDefinition Height="{StaticResource MainSpace}" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <kc:SliderControl
      x:Name="tabControl"
      Margin="0"
      Padding="5"
      CornerRadius="13"
      DisplayMemberPath="Name"
      FontSize="18"
      FontWeight="Bold"
      ItemsSource="{Binding DisplayItems}"
      SliderBackground="{StaticResource PrimaryBrush}"
      SliderCornerRadius="8"
      TabHorizontalAlignment="Left"
      TabWidth="180" />
    <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center">
      <TextBlock VerticalAlignment="Center" Text="{Binding ProcessRatio.ProductionCounter.CacheCount, StringFormat=缓存数：{0}}" />
      <Button
        Margin="10,0"
        VerticalAlignment="Center"
        kc:LanguageResource.Key="导出缓存"
        Command="{s:Action ExportCacheCmd}" />
    </WrapPanel>
    <hc:DialogContainer Grid.Row="2">
      <ContentControl s:View.Model="{Binding ElementName=tabControl, Path=SelectedItem.Content, Mode=OneWay}" />
    </hc:DialogContainer>
  </Grid>
</UserControl>
