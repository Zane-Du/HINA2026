<UserControl
  x:Class="Kinlo.GUI.View.ProductionHistoryView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:hc="https://handyorg.github.io/handycontrol"
  xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
  xmlns:local="clr-namespace:Kinlo.GUI.View"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:s="https://github.com/canton7/Stylet"
  xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
  xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
  d:DataContext="{d:DesignData vm:ProductionHistoryViewModel}"
  d:DesignHeight="450"
  d:DesignWidth="1600"
  mc:Ignorable="d">
  <Border
    Grid.Row="2"
    Grid.ColumnSpan="9"
    Margin="0"
    Background="{DynamicResource RegionBrush}"
    CornerRadius="{DynamicResource MainCornerRadius}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="auto" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <Grid Grid.Row="0" Margin="10,12,15,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="auto" />
          <ColumnDefinition Width="auto" />
          <ColumnDefinition />
          <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>

        <hc:ComboBox
          MinWidth="120"
          MaxHeight="80"
          hc:TitleElement.Title="时间类型"
          ItemsSource="{Binding QueryTimeTypes}"
          SelectedItem="{Binding SelectTimeType}" />
        <WrapPanel Grid.Column="1" VerticalAlignment="Bottom">
          <hc:DateTimePicker
            Grid.Row="1"
            Grid.Column="0"
            Width="160"
            Margin="5,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            hc:InfoElement.Title="{DynamicResource 开始时间}"
            hc:TitleElement.TitlePlacement="Top"
            SelectedDateTime="{Binding StartTime}"
            Style="{StaticResource DateTimePickerPlus}" />
          <TextBlock
            Margin="2,0,2,7"
            VerticalAlignment="Bottom"
            Text="~" />
          <hc:DateTimePicker
            Grid.Row="1"
            Grid.Column="1"
            Width="160"
            Margin="0,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            hc:InfoElement.Title="{DynamicResource 结束时间}"
            hc:TitleElement.TitlePlacement="Top"
            SelectedDateTime="{Binding EndTime}"
            Style="{StaticResource DateTimePickerPlus}" />
        </WrapPanel>
        <hc:TextBox
          Grid.Column="2"
          MaxHeight="80"
          Margin="5,0,0,0"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Bottom"
          hc:InfoElement.Placeholder="单码：支持模糊查询。 多码：须完整匹配，兼容换行与逗号分隔"
          hc:InfoElement.Title="{DynamicResource 输入条码（单码：支持模糊查询。 多码：须完整匹配，兼容换行与逗号分隔）}"
          hc:TitleElement.TitlePlacement="Top"
          AcceptsReturn="True"
          Style="{StaticResource TextBoxExtend}"
          Text="{Binding Barcode, UpdateSourceTrigger=LostFocus}"
          VerticalScrollBarVisibility="Auto" />
        <CheckBox
          Grid.Column="2"
          Margin="0,0,0,3"
          HorizontalAlignment="Right"
          VerticalAlignment="Top"
          Content="条码模糊查询"
          IsChecked="{Binding IsFuzzyQuery}" />
        <WrapPanel Grid.Column="3" VerticalAlignment="Bottom">
          <hc:ComboBox
            MinWidth="120"
            Margin="5,0"
            hc:TitleElement.Title="{DynamicResource 类型}"
            hc:TitleElement.TitlePlacement="Top"
            ItemsSource="{Binding QueryBatteryTypes}"
            SelectedValue="{Binding QueryBatteryType}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{tools:ResourceBinding .}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </hc:ComboBox>
          <hc:ComboBox
            MinWidth="120"
            Margin="0,0,5,0"
            VerticalAlignment="Bottom"
            hc:TitleElement.Title="{DynamicResource MES状态}"
            hc:TitleElement.TitlePlacement="Top"
            ItemsSource="{Binding MesStatuses}"
            SelectedValue="{Binding MesStatus}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{tools:ResourceBinding .}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </hc:ComboBox>
          <CheckBox
            Margin="0,0,0,6"
            VerticalAlignment="Bottom"
            Content="去重"
            IsChecked="{Binding IsNotRepeat}" />
          <Button
            Grid.Row="1"
            Grid.Column="6"
            Width="80"
            Margin="30,0,0,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            hc:BorderElement.CornerRadius="3 0 0 3"
            hc:IconElement.Geometry="{StaticResource SearchGeometry}"
            Command="{s:Action QueryCMD}"
            Content="{DynamicResource 查询}"
            IsDefault="True"
            Style="{StaticResource ButtonPrimary}" />

          <Button
            Grid.Row="1"
            Grid.Column="7"
            Width="80"
            Margin="0,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            hc:BorderElement.CornerRadius="0 3 3 0"
            hc:IconElement.Geometry="{StaticResource DownloadGeometry}"
            Command="{s:Action ExportExcelCMD}"
            Content="{DynamicResource 导出}"
            Style="{StaticResource ButtonSuccess}" />
          <!--<Button
                        Grid.Row="1"
                        Grid.Column="7"
                        Margin="10,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        hc:IconElement.Geometry="{StaticResource DownloadGeometry}"
                        Command="{s:Action ExportExcelDailyDataCMD}"
                        Content="{DynamicResource 导出当天数据}"
                        Style="{StaticResource ButtonInfo}" />-->
          <!--<Button
             Grid.Row="1"
             Grid.Column="7"
             Margin="10,0,0,0"
             HorizontalAlignment="Left"
             VerticalAlignment="Bottom"
             hc:IconElement.Geometry="{StaticResource RotateRightGeometry}"
             Command="{s:Action MaualTrayLoadingCmd}"
             Content="{DynamicResource 物流线手动组盘出站}"
             Style="{StaticResource ButtonSuccess}" />-->
        </WrapPanel>
      </Grid>

      <Grid Grid.Row="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="30" />
          <RowDefinition />
          <RowDefinition Height="38" />
        </Grid.RowDefinitions>
        <Border
          Height="30"
          BorderBrush="{StaticResource BorderBrush}"
          BorderThickness="0,0,0,1">
          <Grid>
            <WrapPanel Margin="12,0,0,0" VerticalAlignment="Center">
              <TextBlock VerticalAlignment="Center" Text="{DynamicResource other_QueryResult}" />
            </WrapPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
              <ToggleButton
                x:Name="entityPropertyVisibleTBut"
                Margin="0,0,10,0"
                Command="{s:Action AdjustCmd}"
                Content="&#xe615;"
                FontFamily="/Font/#iconfont"
                FontSize="18"
                Foreground="#656565"
                IsChecked="{Binding EntityPropertyVisibleVM.IsEntityPropertyVisible}"
                Style="{StaticResource ToggleButtonCustom}"
                ToolTip="{DynamicResource other_DisplayColumns}" />
            </StackPanel>
          </Grid>
        </Border>
        <ContentControl
          Grid.Row="1"
          Margin="10,0,10,0"
          Content="{Binding ShowGridData}" />
        <StackPanel
          Grid.Row="2"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center" Text="{DynamicResource 总计}" />
          <TextBlock VerticalAlignment="Center" Text="{Binding TotalCount}" />
          <TextBlock VerticalAlignment="Center" Text="{DynamicResource 条}" />
          <hc:TextBox
            Margin="20,0,0,0"
            hc:TitleElement.Title="{DynamicResource 每页显示}"
            hc:TitleElement.TitlePlacement="Left"
            Text="{Binding DataCountPerPage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
          <TextBlock
            Margin="5,0,20,0"
            VerticalAlignment="Center"
            Text="{DynamicResource 条}" />
          <hc:Pagination
            HorizontalAlignment="Center"
            DataCountPerPage="{Binding DataCountPerPage}"
            IsJumpEnabled="True"
            MaxPageCount="{Binding TotalPage}"
            MaxPageInterval="4"
            PageUpdated="{s:Action PaginationPageUpdatedCMD}" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</UserControl>
