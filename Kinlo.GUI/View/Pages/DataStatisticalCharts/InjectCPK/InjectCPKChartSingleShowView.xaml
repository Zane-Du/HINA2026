<Window
    x:Class="Kinlo.GUI.View.InjectCPKChartSingleShowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{DynamicResource 图表分析}"
    Width="1600"
    Height="600 "
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d"
>
    <Grid DataContext="{Binding InjectionCpk}">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock HorizontalAlignment="Center" FontSize="15">
            <Run Text="{Binding InjectionNeedleNo}" />
            <Run Text="{DynamicResource 号}" />
            <Run Text="{Binding SelectedGroupType}" />
            <Run Text="      " />
            <Run Text="{DynamicResource CPK:}" />
            <Run Text="{Binding Cpk, StringFormat={}{0:F3}}" />
            <Run Text="      " />
            <Run Text="{DynamicResource 平均值:}" />
            <Run Text="{Binding Average, StringFormat={}{0:F3}}" />
            <Run Text="      " />
            <Run Text="{DynamicResource 标准差:}" />
            <Run Text="{Binding StdDev, StringFormat={}{0:F3}}" />
        </TextBlock>
        <lvc:CartesianChart
            Grid.Row="1"
            Margin="5,5,5,5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            AnimationsSpeed="0"
            LegendPosition="Bottom"
            LegendTextPaint="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.TextPaint}"
            Series="{Binding ChatSeries}"
            TooltipPosition="Right"
            TooltipTextPaint="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.TextPaint}"
            XAxes="{Binding XAxes}"
            YAxes="{Binding YAxes}"
            ZoomMode="X"
        />
    </Grid>
</Window>
