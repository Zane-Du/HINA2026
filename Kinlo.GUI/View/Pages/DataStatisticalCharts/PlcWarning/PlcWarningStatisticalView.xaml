<UserControl
   x:Class="Kinlo.GUI.View.PlcWarningStatisticalView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:s="https://github.com/canton7/Stylet"
   d:DesignHeight="450"
   d:DesignWidth="800"
   mc:Ignorable="d"
>
   <Border
      Grid.Row="0"
      Grid.Column="2"
      Padding="{StaticResource TitlePadding2}"
      Background="{DynamicResource RegionBrush}"
      CornerRadius="{DynamicResource MainCornerRadius}"
   >
      <Grid>
         <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
         </Grid.RowDefinitions>
         <StackPanel Grid.Row="0" Margin="0,0,0,20" Orientation="Horizontal">
            <hc:DateTimePicker
               Grid.Column="0"
               Width="160"
               Margin="0,0,0,0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               hc:InfoElement.Title="{DynamicResource 开始时间}"
               SelectedDateTime="{Binding StartTime}"
               Style="{StaticResource DateTimePickerPlus}"
            />
            <TextBlock Margin="1,0,1,7" VerticalAlignment="Bottom" Text="~" />
            <hc:DateTimePicker
               Grid.Row="1"
               Grid.Column="1"
               Width="160"
               Margin="0,0,10,0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               hc:InfoElement.Title="{DynamicResource 结束时间}"
               SelectedDateTime="{Binding EndTime}"
               Style="{StaticResource DateTimePickerPlus}"
            />
            <hc:ComboBox
               MinWidth="120"
               Margin="0,0,10,0"
               hc:TitleElement.Title="分类统计"
               ItemsSource="{Binding PlcAlarmStats}"
               SelectedValue="{Binding SelectedPlcAlarmStat}"
            />
            <Grid Margin="0,0,10,0">
               <Grid.RowDefinitions>
                  <RowDefinition />
                  <RowDefinition />
               </Grid.RowDefinitions>
               <TextBlock Text="选择报警类型" />
               <hc:CheckComboBox
                  Loaded="checkComboBox_Loaded"
                  x:Name="checkComboBox"
                  Grid.Row="1"
                  ShowSelectAllButton="True"
                  MinWidth="220"
                  ItemsSource="{Binding PlcAlarmLevelTypes}"
               />
            </Grid>

            <Button
               Margin="0"
               VerticalAlignment="Bottom"
               hc:IconElement.Geometry="{StaticResource SearchGeometry}"
               Command="{s:Action QueryCmd}"
               CommandParameter="{Binding  ElementName=checkComboBox}"
               Content="{DynamicResource 统计}"
               Style="{StaticResource ButtonPrimary}"
            />
         </StackPanel>
         <ListBox Grid.Row="1" ItemsSource="{Binding PlcAlarms}" />
      </Grid>
   </Border>
</UserControl>
