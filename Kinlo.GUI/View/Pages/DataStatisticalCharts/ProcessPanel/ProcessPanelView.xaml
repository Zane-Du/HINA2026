<UserControl
    x:Class="Kinlo.GUI.View.ProcessPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    mc:Ignorable="d"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="{StaticResource MainSpace}" />
            <RowDefinition Height="260" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="{StaticResource MainSpace}" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <ContentControl s:View.Model="{Binding ProcessStatisticsVM}" />
        <ContentControl Grid.Column="2" s:View.Model="{Binding CustomStatisticsVM}" />
        <ContentControl Grid.Row="2" Grid.ColumnSpan="3" s:View.Model="{Binding PlcStatusStatisticalVM}" />
    </Grid>
</UserControl>
