<UserControl
   x:Class="Kinlo.GUI.View.TrayStatisticsView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:s="https://github.com/canton7/Stylet"
   d:DesignHeight="580"
   d:DesignWidth="880"
   d:DataContext="{d:DesignInstance vm:TrayStatisticsViewModel}"
   mc:Ignorable="d"
>
   <Border
      Grid.Row="0"
      Grid.Column="2"
      Padding="{StaticResource TitlePadding2}"
      Background="{DynamicResource RegionBrush}"
      CornerRadius="{DynamicResource MainCornerRadius}"
   >
      <Grid>
         <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition />
         </Grid.RowDefinitions>
         <StackPanel Margin="30,10,10,10" Orientation="Horizontal">
            <hc:DateTimePicker
               Grid.Row="1"
               Grid.Column="0"
               Width="160"
               Margin="0,0,0,0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               hc:InfoElement.Title="{DynamicResource 开始时间}"
               SelectedDateTime="{Binding StartTime}"
               Style="{StaticResource DateTimePickerPlus}"
            />
            <TextBlock Margin="1,0,1,7" VerticalAlignment="Bottom" Text="~" />
            <hc:DateTimePicker
               Grid.Row="1"
               Grid.Column="1"
               Width="160"
               Margin="0,0,30,0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               hc:InfoElement.Title="{DynamicResource 结束时间}"
               SelectedDateTime="{Binding EndTime}"
               Style="{StaticResource DateTimePickerPlus}"
            />

            <hc:ButtonGroup VerticalAlignment="Bottom" IsEnabled="{Binding IsQueryFinish}">
               <RadioButton
                  Margin="0"
                  VerticalAlignment="Bottom"
                  hc:BorderElement.CornerRadius="4 0 0 4"
                  hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                  Command="{s:Action QueryTrayCmd}"
                  CommandParameter="1"
                  Content="{DynamicResource 统计注液数据}"
                  Style="{StaticResource RadioButtonIcon}"
               />
               <RibbonRadioButton
                  Margin="0"
                  VerticalAlignment="Bottom"
                  hc:BorderElement.CornerRadius="0 4 4 0"
                  hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                  Command="{s:Action QueryTrayCmd}"
                  CommandParameter="2"
                  Content="{DynamicResource 统计测漏数据}"
                  Style="{StaticResource RadioButtonIcon}"
               />
            </hc:ButtonGroup>
         </StackPanel>
         <TextBlock Grid.Row="1" Margin="30,0" Text="选择托盘号:" />
         <Border
            Grid.Row="2"
            Margin="30,5,10,5"
            Padding="15,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="5"
         >
            <ItemsControl Grid.Column="1" ItemsSource="{Binding TrayNumbers}">
               <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                     <WrapPanel />
                  </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                  <DataTemplate>
                     <RadioButton
                        Margin="8,1"
                        IsChecked="{Binding IsChecked}"
                        Command="{s:Action SelectedTrayNumber}"
                        CommandParameter="{Binding .}"
                        Content="{Binding No}"
                        GroupName="Number"
                     />
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
         </Border>
         <TextBlock Grid.Row="3" Margin="30,0" Text="选择套杯号:" />
         <TextBlock
            Margin="0 8 10 0"
            Foreground="{StaticResource DangerBrush}"
            FontWeight="Bold"
            FontSize="14"
            kc:LanguageResource.Key="*** 点击 色块 可查看详情 ***"
            Grid.Row="5"
            HorizontalAlignment="Right"
         />
         <Border
            Grid.Row="4"
            Margin="30,5,10,5"
            Padding="15,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="5"
         >
            <ItemsControl Grid.Column="1" ItemsSource="{Binding CupNumbers}">
               <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                     <WrapPanel />
                  </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                  <DataTemplate>
                     <RadioButton
                        IsChecked="{Binding IsChecked}"
                        Margin="8,1"
                        Command="{s:Action SelectedCupNumber}"
                        CommandParameter="{Binding .}"
                        Content="{Binding No}"
                        GroupName="Number"
                     />
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
         </Border>
         <Grid Grid.Row="5" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="20" />
               <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
               <RowDefinition />
               <RowDefinition Height="20" />
            </Grid.RowDefinitions>
            <ItemsControl Grid.Row="1" Grid.Column="1" ItemsSource="{Binding ColumnInfos}">
               <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                     <UniformGrid Columns="{Binding Columns}" Rows="1" />
                  </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                  <DataTemplate>
                     <TextBlock
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource TextBlockTitleBold}"
                        Text="{Binding  No, StringFormat={}{0}}"
                     />
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl Grid.Row="0" Grid.Column="0" ItemsSource="{Binding RowInfos}">
               <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                     <UniformGrid Columns="1" Rows="{Binding Rows}" />
                  </ItemsPanelTemplate>
               </ItemsControl.ItemsPanel>
               <ItemsControl.ItemTemplate>
                  <DataTemplate>
                     <TextBlock
                        Margin="2,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource TextBlockTitleBold}"
                        Text="{Binding  No, StringFormat={}{0}}"
                     >
                        <TextBlock.LayoutTransform>
                           <RotateTransform Angle="0" />
                        </TextBlock.LayoutTransform>
                     </TextBlock>
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Border Grid.Row="0" Grid.Column="1" Padding="3" BorderThickness="1" CornerRadius="5">
               <ItemsControl ItemsSource="{Binding TrayDatas}">
                  <ItemsControl.ItemsPanel>
                     <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Columns}" Rows="{Binding Rows}" />
                     </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                     <DataTemplate>
                        <Grid Margin="5">
                           <Grid.RowDefinitions>
                              <RowDefinition />
                              <RowDefinition Height="0" />
                           </Grid.RowDefinitions>

                           <Grid Loaded="Root_Loaded" SizeChanged="Root_SizeChanged">
                              <!-- 外层：背景 + 圆角 -->
                              <Border Background="{StaticResource DangerBrush}" />

                              <!-- 内层：普通矩形 -->
                              <Rectangle
                                 Fill="{StaticResource InfoBrush}"
                                 HorizontalAlignment="Stretch"
                                 RenderTransformOrigin="0,0.5"
                              >
                                 <Rectangle.RenderTransform>
                                    <ScaleTransform ScaleX="{Binding OKProportion, Mode=OneWay}" />
                                 </Rectangle.RenderTransform>
                              </Rectangle>
                           </Grid>
                           <Grid Grid.Row="0" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                              <Grid.RowDefinitions>
                                 <RowDefinition />
                                 <RowDefinition Height="1.1*" />
                              </Grid.RowDefinitions>
                              <Viewbox Grid.Row="1" VerticalAlignment="Bottom">
                                 <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    FontWeight="UltraBold"
                                    Foreground="Black"
                                    Text="{Binding OKProportion, Mode=OneWay, StringFormat=P2}"
                                 />
                              </Viewbox>
                              <Viewbox Margin="5,5,0,0" HorizontalAlignment="Left">
                                 <StackPanel>
                                    <TextBlock>
                                       <Run Text="OK:" />
                                       <Run Text="{Binding OK, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock>
                                       <Run Text="NG:" />
                                       <Run Text="{Binding NG, Mode=OneWay}" />
                                    </TextBlock>
                                 </StackPanel>
                              </Viewbox>
                           </Grid>

                           <Button
                              Cursor="Hand"
                              VerticalContentAlignment="Bottom"
                              Padding="0 0 0 50"
                              Command="{s:Action ShowDetailCmd}"
                              Foreground="White"
                              Opacity="1"
                              CommandParameter="{Binding .}"
                              Height="{Binding RelativeSource={RelativeSource AncestorType=Grid}, Path=ActualHeight}"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              BorderThickness="0"
                           />
                        </Grid>
                     </DataTemplate>
                  </ItemsControl.ItemTemplate>
               </ItemsControl>
            </Border>
         </Grid>
      </Grid>
   </Border>
</UserControl>
