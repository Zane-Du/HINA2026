<UserControl
    x:Class="Kinlo.GUI.View.PlcStatusStatisticalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
>
    <Border
        Grid.Row="0"
        Grid.Column="2"
        Padding="{StaticResource TitlePadding2}"
        Background="{DynamicResource RegionBrush}"
        CornerRadius="{DynamicResource MainCornerRadius}"
    >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Left" kc:LanguageResource.Key="PLC状态" Style="{StaticResource TextBlockSubTitleBold}" />
            <StackPanel Grid.Row="1" Margin="50,0,0,20" Orientation="Horizontal">
                <hc:DateTimePicker
                    Grid.Column="0"
                    Width="160"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    hc:InfoElement.Title="{DynamicResource 开始时间}"
                    SelectedDateTime="{Binding StartTime}"
                    Style="{StaticResource DateTimePickerPlus}"
                />
                <TextBlock Margin="1,0,1,7" VerticalAlignment="Bottom" Text="~" />
                <hc:DateTimePicker
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="160"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    hc:InfoElement.Title="{DynamicResource 结束时间}"
                    SelectedDateTime="{Binding EndTime}"
                    Style="{StaticResource DateTimePickerPlus}"
                />
                <Button
                    Margin="0"
                    VerticalAlignment="Bottom"
                    hc:IconElement.Geometry="{StaticResource SearchGeometry}"
                    Command="{s:Action QueryCmd}"
                    Content="{DynamicResource 统计}"
                    Style="{StaticResource ButtonPrimary}"
                />
            </StackPanel>
            <kc:OverlappingStateTimelineChart
                Grid.Row="2"
                Height="90"
                Margin="20,0,20,10"
                HorizontalAlignment="Stretch"
                CornerRadius="6"
                Foreground="Black"
                Items="{Binding TimelineItems}"
            />
        </Grid>
    </Border>
</UserControl>
