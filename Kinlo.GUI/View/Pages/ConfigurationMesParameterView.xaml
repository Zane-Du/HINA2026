<UserControl
    x:Class="Kinlo.GUI.View.ConfigurationMesParameterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cfg="clr-namespace:Kinlo.Common.Configurations;assembly=Kinlo.Common"
    xmlns:cvt="clr-namespace:Kinlo.Common.Converters;assembly=Kinlo.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    d:DataContext="{d:DesignInstance vm:ConfigurationMesParameterViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="1600"
    mc:Ignorable="d"
>
    <UserControl.Resources>
        <cvt:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="{StaticResource MainSpace}" />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.ColumnSpan="3">
            <Grid Margin="0,0,0,4">
                <kc:SliderControl
                    x:Name="tabControl"
                    Height="60"
                    Margin="0"
                    Padding="5"
                    CornerRadius="{DynamicResource MainCornerRadius}"
                    FontSize="18"
                    FontWeight="Bold"
                    SliderBackground="{StaticResource PrimaryBrush}"
                    SliderCornerRadius="5"
                    TabHorizontalAlignment="Left"
                    TabWidth="220"
                >
                    <kc:SliderControl.ItemsSource>
                        <x:Array Type="{x:Type sys:String}">
                            <sys:String>MES结果参数</sys:String>
                            <sys:String>MES开机参数</sys:String>
                        </x:Array>
                    </kc:SliderControl.ItemsSource>
                </kc:SliderControl>
                <WrapPanel Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Text="{Binding DisplayCount, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=显示推荐个数  {0}}"
                        />
                        <Slider
                            Grid.Row="1"
                            Width="200"
                            Margin="0,15,0,0"
                            VerticalAlignment="Center"
                            Maximum="20"
                            Minimum="1"
                            Value="{Binding DisplayCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        />
                    </Grid>
                    <Grid Margin="0,0,0,0">
                        <TextBlock
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Foreground="{DynamicResource PrimaryBrush}"
                            Text="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=相似度阈值 {0:0.00}}"
                        />
                        <Slider
                            Grid.Row="1"
                            Width="200"
                            Margin="0,15,0,0"
                            Padding="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Maximum="1"
                            Minimum="0"
                            Value="{Binding Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        />
                    </Grid>

                    <Button
                        Margin="20,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="4 0 0 4"
                        Command="{s:Action OpenRecommendedCmd}"
                        Content="推荐本地属性"
                        Style="{StaticResource ButtonInfo}"
                    />
                    <Button
                        Margin="0,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="0"
                        Command="{s:Action UseHighestSimilarityCmd}"
                        Content="应用相似度最高属性"
                        Style="{StaticResource ButtonPrimary}"
                    />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="0"
                        Command="{s:Action ClearRecommendedCmd}"
                        Content="关闭推荐属性"
                        Style="{StaticResource ButtonSuccess}"
                    />
                    <Button
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="0 4 4 0"
                        Command="{s:Action ClearLocalCmd}"
                        Content="清除本地属性"
                        Style="{StaticResource ButtonDanger}"
                    />

                    <Button
                        Width="100"
                        Margin="50,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="4 0 0 4"
                        Command="{s:Action ImportExcelCmd}"
                        Style="{StaticResource ButtonInfo}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe62b;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="Excel导入" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Row="1"
                        Grid.Column="7"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius=" 0"
                        hc:IconElement.Geometry="{StaticResource DownloadGeometry}"
                        Command="{s:Action ExportExcelCmd}"
                        Content="导出Excel"
                        Style="{StaticResource ButtonPrimary}"
                    />
                    <Button
                        Width="100"
                        Margin="0,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        hc:BorderElement.CornerRadius="0 4 4 0"
                        Command="{s:Action SaveCMD}"
                        Style="{StaticResource ButtonSuccess}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe61b;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="{DynamicResource 保存}" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Grid>
        <Border Grid.Row="1" Padding="0" Background="{DynamicResource RegionBrush}" CornerRadius="{StaticResource MainCornerRadius}" />
        <DataGrid
            x:Name="ResultParamDataGrid"
            Grid.Row="1"
            Margin="0,0,0,0"
            hc:DataGridAttach.ShowRowNumber="True"
            AutoGenerateColumns="False"
            Background="Transparent"
            BorderThickness="0,0,0,0"
            CellStyle="{DynamicResource OtherDisplayDataGridCellStyle}"
            ItemsSource="{Binding MesParameterCopy.ResultParameters}"
            RowHeight="35"
            SelectionMode="Single"
            SelectionUnit="FullRow"
        >
            <DataGrid.Visibility>
                <Binding Converter="{StaticResource IntToVisibilityConverter}" ElementName="tabControl" Path="SelectedIndex">
                    <Binding.ConverterParameter>
                        <sys:Int32>0</sys:Int32>
                    </Binding.ConverterParameter>
                </Binding>
            </DataGrid.Visibility>
            <DataGrid.RowStyle>
                <Style BasedOn="{StaticResource OtherDisplayDataGridRowStyle}" TargetType="DataGridRow">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="auto" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel Margin="8,0,0,0">
                                <Button
                                    Padding="8,0"
                                    Command="{s:Action RemoveResultParamCmd}"
                                    CommandParameter="{Binding}"
                                    Content="&#xe648;"
                                    FontFamily="/Font/#iconfont"
                                    FontSize="16"
                                    Foreground="Red"
                                    Style="{StaticResource ButtonCustom}"
                                />
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="50" Header="启用">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="auto" Header="是否失效" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsExpired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--<DataGridTemplateColumn
                    Width="auto"
                    Header="选中"
                    IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->

                <DataGridTemplateColumn Header="Mes编号">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                VerticalAlignment="Stretch"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding MesCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Mes名称">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                Margin="10,0"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding MesName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn MinWidth="200" Binding="{Binding LocalPropertyName}" Header="本地属性" IsReadOnly="True" />
                <DataGridTemplateColumn MinWidth="180" Header="本地名称">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="15,0,0,0" Background="Transparent" Text="{tools:ResourceBinding LanguagerKey}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="本地推荐属性" Visibility="Collapsed">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Candidates}"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                Style="{StaticResource ListBoxCustom}"
                            >
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Height="25"
                                            Margin="8,0"
                                            VerticalAlignment="Top"
                                            Command="{s:Action SelectedCmd}"
                                            CommandParameter="{Binding .}"
                                            Content="{Binding Description}"
                                            Foreground="{DynamicResource PrimaryBrush}"
                                            Style="{StaticResource ButtonCustom}"
                                        />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="auto" Header="转换器">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{x:Static cfg:MesParameterConfig.MesValueConverterNames}"
                                SelectedValue="{Binding ConverterName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="转换器参数">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                Margin="0,0,20,0"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding ConverterParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="备注">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                Margin="0,0,20,0"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid
            Grid.Row="1"
            Margin="0,0,10,0"
            hc:DataGridAttach.ShowRowNumber="True"
            AutoGenerateColumns="False"
            Background="Transparent"
            BorderThickness="0,0,0,0"
            CellStyle="{DynamicResource OtherDisplayDataGridCellStyle}"
            ItemsSource="{Binding MesParameterCopy.DeviceStartupParameters}"
            RowHeight="35"
            SelectionMode="Single"
            SelectionUnit="FullRow"
        >
            <DataGrid.Visibility>
                <Binding Converter="{StaticResource IntToVisibilityConverter}" ElementName="tabControl" Path="SelectedIndex">
                    <Binding.ConverterParameter>
                        <sys:Int32>1</sys:Int32>
                    </Binding.ConverterParameter>
                </Binding>
            </DataGrid.Visibility>
            <DataGrid.RowStyle>
                <Style BasedOn="{StaticResource OtherDisplayDataGridRowStyle}" TargetType="DataGridRow">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel Margin="8,0,0,0">
                                <Button
                                    Padding="8,0"
                                    Command="{s:Action RemoveStartDeviceCmd}"
                                    CommandParameter="{Binding}"
                                    Content="&#xe648;"
                                    FontFamily="/Font/#iconfont"
                                    FontSize="16"
                                    Foreground="Red"
                                    Style="{StaticResource ButtonCustom}"
                                />
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="启用">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100" Header="是否失效" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsExpired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="50" Header="选中" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn MinWidth="180" Header="本地名称">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Margin="15,0,0,0" Text="{tools:ResourceBinding LanguagerKey}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn MinWidth="200" Binding="{Binding LocalPropertyName}" Header="本地属性" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Mes编号">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                MinWidth="200"
                                VerticalAlignment="Stretch"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding MesCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Mes名称">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                MinWidth="200"
                                Margin="10,0"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding MesName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="auto" Header="MES数据类型">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Source={StaticResource MesDataTypeEnum}}"
                                SelectedValue="{Binding MesDataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="auto" Header="转换器">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,1" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Source={StaticResource MesDataConverterEnum}}"
                                SelectedValue="{Binding MesDataConverter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="备注">
                    <DataGridTemplateColumn.CellStyle>
                        <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <!--<Setter Property="BorderThickness" Value="0,0,0,0" />-->
                            <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <hc:TextBox
                                MinWidth="200"
                                Margin="0,0,20,0"
                                hc:BorderElement.CornerRadius="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <hc:ScrollViewer Grid.Row="1" Grid.Column="2" Width="260" Margin="0,0,0,0" HorizontalAlignment="Right">
            <hc:ScrollViewer.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Rectangle
                            Width="{Binding RelativeSource={RelativeSource AncestorType=hc:ScrollViewer}, Path=ActualWidth}"
                            Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=hc:ScrollViewer}}"
                            Fill="Black"
                            RadiusX="{DynamicResource MainCornerRadiusDouble}"
                            RadiusY="{DynamicResource MainCornerRadiusDouble}"
                        />
                    </VisualBrush.Visual>
                </VisualBrush>
            </hc:ScrollViewer.OpacityMask>
            <Border Padding="0" Background="{DynamicResource RegionBrush}">
                <Grid>
                    <ItemsControl x:Name="itemsControl" ItemsSource="{Binding DisplayData.AvailableResultParameters}">
                        <ItemsControl.Visibility>
                            <Binding Converter="{StaticResource IntToVisibilityConverter}" ElementName="tabControl" Path="SelectedIndex">
                                <Binding.ConverterParameter>
                                    <sys:Int32>0</sys:Int32>
                                </Binding.ConverterParameter>
                            </Binding>
                        </ItemsControl.Visibility>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander
                                    hc:BorderElement.CornerRadius="0"
                                    Background="Transparent"
                                    BorderThickness="0,0,0,1"
                                    Header="{tools:ResourceBinding Processes}"
                                    IsExpanded="{Binding IsSelected, Mode=TwoWay}"
                                >
                                    <ListBox hc:BorderElement.CornerRadius="0" BorderThickness="0,0,0,1" ItemsSource="{Binding OriginalClassProperties}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="auto" />
                                                        <ColumnDefinition />
                                                    </Grid.ColumnDefinitions>
                                                    <WrapPanel VerticalAlignment="Center">
                                                        <Button
                                                            Height="22"
                                                            Padding="6,0"
                                                            hc:BorderElement.CornerRadius="4 0 0 4"
                                                            Command="{s:Action AddReslutParamCmd}"
                                                            CommandParameter="{Binding .}"
                                                            Content="新建"
                                                            Style="{StaticResource ButtonSuccess.Small}"
                                                        />
                                                        <Button
                                                            Height="22"
                                                            Padding="6,0"
                                                            hc:BorderElement.CornerRadius="0 4 4 0"
                                                            Command="{s:Action ReplaceReslutParamCmd}"
                                                            CommandParameter="{Binding .}"
                                                            Content="替换"
                                                            Style="{StaticResource ButtonDanger.Small}"
                                                        />
                                                    </WrapPanel>
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Margin="5,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Text="{tools:ResourceBinding Description}"
                                                    />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Expander
                        Width="260"
                        hc:BorderElement.CornerRadius="0"
                        Background="Transparent"
                        BorderThickness="0,0,0,1"
                        Header="运行参数"
                        IsExpanded="True"
                    >
                        <Expander.Visibility>
                            <Binding Converter="{StaticResource IntToVisibilityConverter}" ElementName="tabControl" Path="SelectedIndex">
                                <Binding.ConverterParameter>
                                    <sys:Int32>1</sys:Int32>
                                </Binding.ConverterParameter>
                            </Binding>
                        </Expander.Visibility>
                        <ListBox hc:BorderElement.CornerRadius="0" BorderThickness="0,0,0,1" ItemsSource="{Binding Role.RunParameters}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto" />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <WrapPanel VerticalAlignment="Center">
                                            <Button
                                                Height="22"
                                                Padding="6,0"
                                                hc:BorderElement.CornerRadius="4 0 0 4"
                                                Command="{s:Action AddStartDeviceParamCmd}"
                                                CommandParameter="{Binding .}"
                                                Content="新建"
                                                Style="{StaticResource ButtonSuccess.Small}"
                                            />
                                            <Button
                                                Height="22"
                                                Padding="6,0"
                                                hc:BorderElement.CornerRadius="0 4 4 0"
                                                Command="{s:Action ReplaceStartupParamCmd}"
                                                CommandParameter="{Binding .}"
                                                Content="替换"
                                                Style="{StaticResource ButtonDanger.Small}"
                                            />
                                        </WrapPanel>
                                        <TextBlock Grid.Column="1" Margin="5,0,0,0" Text="{tools:ResourceBinding DisplayName}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>
                </Grid>
            </Border>
        </hc:ScrollViewer>
        <WrapPanel Grid.Row="1" Grid.Column="2" Margin="0,8,35,0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button
                VerticalAlignment="Top"
                Command="{s:Action ExpandCmd}"
                Content="展开全部"
                FontSize="10"
                Foreground="{StaticResource PrimaryBrush}"
                Style="{StaticResource ButtonCustom}"
            />
            <Button
                Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Top"
                Command="{s:Action FoldCmd}"
                Content="折叠全部"
                FontSize="10"
                Foreground="{StaticResource PrimaryBrush}"
                Style="{StaticResource ButtonCustom}"
            />
        </WrapPanel>
    </Grid>
</UserControl>
