<UserControl
    x:Class="Kinlo.GUI.View.LogHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="{StaticResource MainSpace}" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <kc:SliderControl
            x:Name="tabControl"
            Margin="0"
            Padding="5"
            CornerRadius="13"
            DisplayMemberPath="Log4NetType"
            FontSize="18"
            FontWeight="Bold"
            ItemsSource="{Binding LogHistorys}"
            SelectedIndex="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.SelectIndex, Mode=TwoWay}"
            SliderBackground="{StaticResource PrimaryBrush}"
            SliderCornerRadius="8"
            TabHorizontalAlignment="Left"
            TabWidth="180"
        />

        <StackPanel Margin="0,0,15,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
            <Button
                Height="30"
                Margin="0,0,10,0"
                Padding="10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{s:Action OpenLogCMD}"
                Style="{StaticResource ButtonInfo}"
            >
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="/Font/#iconfont"
                        FontSize="16"
                        Text="&#xe616;"
                    />
                    <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="用记事本打开当前日志" FontSize="14" />
                </StackPanel>
            </Button>
            <Button
                Height="30"
                Margin="0,0,0,0"
                Padding="10,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{s:Action OpenLogDirCMD}"
                Style="{StaticResource ButtonSuccess}"
            >
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="/Font/#iconfont"
                        FontSize="16"
                        Text="&#xe6ed;"
                    />
                    <TextBlock VerticalAlignment="Center" FontSize="14" Text="{DynamicResource 打开日志位置}" />
                </StackPanel>
            </Button>
        </StackPanel>
        <Border
            Grid.Row="2"
            Grid.Column="0"
            Padding="{StaticResource TitlePadding2}"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="{DynamicResource MainCornerRadius}"
        >
            <ContentControl Content="{Binding LogVM}" />
        </Border>
    </Grid>
</UserControl>
