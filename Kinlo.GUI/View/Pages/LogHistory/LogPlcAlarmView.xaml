<Grid
    x:Class="Kinlo.GUI.View.LogPlcAlarmView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    IsEnabled="True"
    VirtualizingStackPanel.IsVirtualizing="True"
    VirtualizingStackPanel.VirtualizationMode="Recycling"
    mc:Ignorable="d"
>
    <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition Width="50" />
        <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
        <RowDefinition Height="60" />
        <RowDefinition />
    </Grid.RowDefinitions>
    <TextBlock Margin="15,10,0,0" HorizontalAlignment="Left" FontSize="30" Text="PLC报警中..." />
    <TextBlock Grid.Column="2" Margin="15,10,0,0" HorizontalAlignment="Left" FontSize="30" Text="PLC报警历史" />
    <ListView
        Grid.Row="1"
        Background="Transparent"
        BorderThickness="0"
        ItemContainerStyle="{StaticResource LogListViewItemStyle}"
        ItemsSource="{Binding CurrentAlarms}"
    >
        <ListView.View>
            <GridView>
                <GridView.Columns>
                    <GridViewColumn Width="60" DisplayMemberBinding="{Binding PlcAalrmLevel}" Header="等级" />
                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Header="开始时间" />
                    <GridViewColumn Width="125" DisplayMemberBinding="{Binding PlcTag}" Header="标签位置" />
                    <GridViewColumn Header="{DynamicResource 信息}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <hc:SimpleText
                                    MinWidth="1500"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                    Text="{Binding AlarmMessage}"
                                    TextWrapping="Wrap"
                                >
                                    <hc:SimpleText.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Click="CopyLogMessage_Click" Header="{DynamicResource 复制}" />
                                        </ContextMenu>
                                    </hc:SimpleText.ContextMenu>
                                </hc:SimpleText>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView.Columns>
            </GridView>
        </ListView.View>
    </ListView>
    <ListView
        Grid.Row="1"
        Grid.Column="2"
        Background="Transparent"
        BorderThickness="0"
        ItemContainerStyle="{StaticResource LogListViewItemStyle}"
        ItemsSource="{Binding ClearedAlarms}"
    >
        <ListView.View>
            <GridView>
                <GridView.Columns>
                    <GridViewColumn Width="60" DisplayMemberBinding="{Binding PlcAalrmLevel}" Header="等级" />
                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Header="开始时间" />
                    <GridViewColumn Width="150" DisplayMemberBinding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Header="结束时间" />
                    <GridViewColumn Width="125" DisplayMemberBinding="{Binding PlcTag}" Header="标签位置" />
                    <GridViewColumn Header="{DynamicResource 信息}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <hc:SimpleText
                                    MinWidth="1500"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                    Text="{Binding AlarmMessage}"
                                    TextWrapping="Wrap"
                                >
                                    <hc:SimpleText.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Click="CopyLogMessage_Click" Header="{DynamicResource 复制}" />
                                        </ContextMenu>
                                    </hc:SimpleText.ContextMenu>
                                </hc:SimpleText>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView.Columns>
            </GridView>
        </ListView.View>
    </ListView>
    <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Width="0.8" Background="{StaticResource BorderBrush}" />

    <GridSplitter Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />
</Grid>
