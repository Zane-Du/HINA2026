<UserControl
   x:Class="Kinlo.GUI.View.LogRunAnalysisView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   d:DataContext="{d:DesignInstance local:LogRunAnalysisView}"
   d:DesignHeight="450"
   d:DesignWidth="1400"
   mc:Ignorable="d"
>
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="auto" />
         <RowDefinition />
      </Grid.RowDefinitions>
      <WrapPanel Margin="0,10,0,10" IsEnabled="{Binding IsInfoLoaded}">
         <hc:DateTimePicker
            Grid.Row="1"
            Grid.Column="0"
            Width="180"
            Margin="0,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            hc:InfoElement.Title="开始时间："
            hc:TitleElement.TitlePlacement="Top"
            DateTimeFormat="yyyy-MM-dd HH:00:00"
            SelectedDateTime="{Binding StartTime}"
            Style="{StaticResource DateTimePickerPlus}"
         />
         <TextBlock Margin="2,0,2,7" VerticalAlignment="Bottom" Text="~" />
         <hc:DateTimePicker
            Grid.Row="1"
            Grid.Column="1"
            Width="180"
            Margin="0,0,0,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Bottom"
            hc:InfoElement.Title="结束时间："
            hc:TitleElement.TitlePlacement="Top"
            DateTimeFormat="yyyy-MM-dd HH:00:00"
            SelectedDateTime="{Binding EndTime}"
            Style="{StaticResource DateTimePickerPlus}"
         />

         <hc:ComboBox
            MinWidth="120"
            Margin="10,0,10,0"
            hc:TitleElement.Title="PLC："
            IsEditable="True"
            ItemsSource="{Binding PlcNames}"
            Text="{Binding PlcName}"
         />
         <hc:ComboBox
            MinWidth="160"
            hc:TitleElement.Title="工序："
            IsEditable="True"
            ItemsSource="{Binding Processes}"
            Text="{Binding Process}"
         />
         <hc:ComboBox
            MinWidth="80"
            Margin="10,0,10,0"
            hc:TitleElement.Title="通道："
            IsEditable="True"
            ItemsSource="{Binding Lanes}"
            Text="{Binding Lane}"
         />
         <Grid>
            <WrapPanel VerticalAlignment="Top">
               <RadioButton Margin="0,0,0,0" Content="ID" IsChecked="{Binding IsId}" />
               <RadioButton Margin="10,0,0,0" kc:LanguageResource.Key="条码" />
            </WrapPanel>
            <hc:TextBox Width="260" hc:TitleElement.Title=" " Text="{Binding IdOrBarcode}" />
         </Grid>
         <Button
            Margin="10,0,10,0"
            Padding="15,0"
            VerticalAlignment="Bottom"
            kc:LanguageResource.Key="确定"
            Click="Button_Click_Read"
            Style="{StaticResource ButtonSuccess}"
         />
         <Button
            Margin="0,0"
            Padding="15,0"
            VerticalAlignment="Bottom"
            hc:BorderElement.CornerRadius="4 0 0 4"
            kc:LanguageResource.Key="复制选中"
            Click="Button_Click_Copy"
            Style="{StaticResource ButtonInfo}"
         />
         <Button
            Margin="0,0"
            Padding="15,0"
            VerticalAlignment="Bottom"
            hc:BorderElement.CornerRadius="0 0 0 0"
            kc:LanguageResource.Key="保存"
            Click="Button_Click_Save"
            Style="{StaticResource ButtonPrimary}"
         />

         <Button
            Margin="0,0"
            Padding="15,0"
            VerticalAlignment="Bottom"
            hc:BorderElement.CornerRadius="0 4 4 0"
            kc:LanguageResource.Key="保存并用记事本打开"
            Click="Button_Click_SaveAndOpen"
            Style="{StaticResource   ButtonDanger}"
         />
      </WrapPanel>
      <ListBox
         Grid.Row="1"
         x:Name="listBox"
         ItemsSource="{Binding LogEntries}"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         VirtualizingStackPanel.IsVirtualizing="True"
         VirtualizingStackPanel.VirtualizationMode="Recycling"
      ></ListBox>
   </Grid>
</UserControl>
