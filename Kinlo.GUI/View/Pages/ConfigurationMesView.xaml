<UserControl
    x:Class="Kinlo.GUI.View.ConfigurationMesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:Kinlo.Common.Converters;assembly=Kinlo.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    d:DataContext="{d:DesignInstance vm:ConfigurationMesViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="1600"
    mc:Ignorable="d"
>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="{StaticResource TitleSpace}" />
            <RowDefinition Height="{StaticResource MainSpace}" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Border
            Grid.ColumnSpan="5"
            Padding="{StaticResource TitlePadding1}"
            Background="{DynamicResource RegionBrush}"
            CornerRadius="{DynamicResource MainCornerRadius}"
        >
            <Grid>
                <TextBlock
                    Margin="0,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{DynamicResource TextBlockTitleBold}"
                    Text="{tools:ResourceBinding MesParameterCopy.MesName}"
                />
                <StackPanel Margin="0,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button
                        Width="100"
                        Height="30"
                        Margin="0,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Command="{s:Action SaveCMD}"
                        Style="{StaticResource ButtonSuccess}"
                    >
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,8,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="/Font/#iconfont"
                                FontSize="16"
                                Text="&#xe61b;"
                            />
                            <TextBlock VerticalAlignment="Center" FontSize="14" Text="{DynamicResource 保存}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="{StaticResource MainSpace}" />
                <ColumnDefinition Width="600" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="{StaticResource MainSpace}" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="{StaticResource MainSpace}" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" />

            <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="auto" />
                        <RowDefinition />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Style="{DynamicResource TextBlockSubTitleBold}"
                        Text="{DynamicResource MES接口}"
                    />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="30" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <hc:TextBox
                            Grid.Row="0"
                            Height="30"
                            VerticalAlignment="Center"
                            hc:TitleElement.Title="{DynamicResource 服务器地址1}"
                            hc:TitleElement.TitlePlacement="Left"
                            Text="{Binding MesParameterCopy.MesInterfaceInfo.BaseAddress}"
                        />
                        <hc:TextBox
                            Grid.Row="0"
                            Grid.Column="2"
                            Height="30"
                            VerticalAlignment="Center"
                            hc:TitleElement.Title="{DynamicResource 服务器地址2}"
                            hc:TitleElement.TitlePlacement="Left"
                            Text="{Binding MesParameterCopy.MesInterfaceInfo.BaseAddress2}"
                        />
                        <!--<hc:TextBox
                            Grid.Column="2"
                            Height="30"
                            hc:TitleElement.Title="{DynamicResource MES网口IP}"
                            hc:TitleElement.TitlePlacement="Left"
                            hc:TitleElement.TitleWidth="90"
                            Text="{Binding MesParameterCopy.MesInterfaceInfo.LocalMesIP}" />-->
                        <hc:TextBox
                            Grid.Row="0"
                            Grid.Column="4"
                            Height="30"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Stretch"
                            hc:TitleElement.Title="{DynamicResource 超时时间(ms)}"
                            hc:TitleElement.TitlePlacement="Left"
                            Text="{Binding MesParameterCopy.MesInterfaceInfo.Timeout}"
                        />

                        <StackPanel Grid.Row="2" Margin="0,15,0,-5" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="4 0 0 4"
                                kc:LanguageResource.Key="全选"
                                Command="{s:Action SelectAllCmd}"
                                Style="{StaticResource ButtonPrimary}"
                            />
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="0"
                                kc:LanguageResource.Key="全不选"
                                Command="{s:Action DeselectAllCmd}"
                                Style="{StaticResource ButtonDanger}"
                            />
                            <Button
                                Width="80"
                                Height="25"
                                Padding="0"
                                VerticalAlignment="Bottom"
                                hc:BorderElement.CornerRadius="0 4 4 0"
                                kc:LanguageResource.Key="反选"
                                Command="{s:Action InvertSelectionCmd}"
                                Style="{StaticResource ButtonInfo}"
                            />
                        </StackPanel>
                    </Grid>
                    <!--<Border
                        VerticalAlignment="Bottom"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" />-->
                    <DataGrid
                        Grid.Row="2"
                        Margin="0,0,0,0"
                        d:ItemsSource="{d:SampleData ItemCount=5}"
                        AutoGenerateColumns="False"
                        Background="Transparent"
                        BorderThickness="0"
                        CellStyle="{DynamicResource OtherDisplayDataGridCellStyle}"
                        ItemsSource="{Binding MesParameterCopy.MesInterfaceInfo.MesParameterItems}"
                        RowHeight="35"
                        RowStyle="{StaticResource OtherDisplayDataGridRowStyle}"
                        SelectionUnit="Cell"
                    >
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock
                                        Margin="-10,0,0,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="{DynamicResource 启用}"
                                    />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="{DynamicResource 接口}" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Text="{tools:ResourceBinding InterfaceName}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="轮询间隔(s)" FontSize="14" FontWeight="Bold" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Margin="0,0,0,0"
                                            hc:BorderElement.CornerRadius="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Text="{Binding PollingIntervalSec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="auto">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="{DynamicResource 服务器}" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox
                                            hc:BorderElement.CornerRadius="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=DataContext.BaseIndexs}"
                                            SelectedValue="{Binding BserUrlIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                        <!--<TextBox
                                            Margin="0,0,20,0"
                                            hc:BorderElement.CornerRadius="0"
                                            BorderThickness="0,0,0,1"
                                            Text="{Binding Frequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />-->
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style BasedOn="{StaticResource OtherDisplayDataGridCellStyle}" TargetType="DataGridCell">
                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <!--<Setter Property="BorderBrush" Value="{DynamicResource SecondaryBorderBrush}" />-->
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.Header>
                                    <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="路由" FontSize="14" FontWeight="Bold" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox
                                            Margin="0,0,0,0"
                                            hc:BorderElement.CornerRadius="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Width="40"
                                            Padding="0"
                                            HorizontalAlignment="Right"
                                            Command="{s:Action MesTestCMD}"
                                            CommandParameter="{Binding}"
                                            Content="{DynamicResource 测试}"
                                            Style="{StaticResource ButtonPrimary}"
                                        />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Border Grid.Row="2" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Style="{DynamicResource TextBlockSubTitleBold}"
                        Text="{DynamicResource MQTT配置}"
                    />
                    <CheckBox
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="100,3,0,0"
                        VerticalAlignment="Top"
                        Content="启用"
                        IsChecked="{Binding MesParameterCopy.MqttServiceInfo.Enable}"
                    />
                    <Button
                        Grid.Column="6"
                        Grid.ColumnSpan="2"
                        Width="50"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{s:Action MqttTestCMD}"
                        Content="{DynamicResource 测试}"
                        Style="{StaticResource ButtonPrimary}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Height="30"
                        Margin="0,0,0,0"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="{DynamicResource MQTT服务地址}"
                        hc:TitleElement.TitlePlacement="Left"
                        Text="{Binding MesParameterCopy.MqttServiceInfo.BrokerAddress}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Grid.Column="2"
                        Height="30"
                        hc:TitleElement.Title="{DynamicResource MQTT主题}"
                        hc:TitleElement.TitlePlacement="Left"
                        Text="{Binding MesParameterCopy.MqttServiceInfo.Topic}"
                    />

                    <hc:TextBox
                        Grid.Row="1"
                        Grid.Column="4"
                        Width="160"
                        Height="30"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="{DynamicResource MQTT端口}"
                        hc:TitleElement.TitlePlacement="Left"
                        Text="{Binding MesParameterCopy.MqttServiceInfo.Port}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Grid.Column="6"
                        Width="160"
                        Height="30"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="{DynamicResource 间隔时间(ms)}"
                        hc:TitleElement.TitlePlacement="Left"
                        Text="{Binding MesParameterCopy.MqttServiceInfo.Interval}"
                    />
                </Grid>
            </Border>
            <Border Grid.Row="4" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width=".5*" />
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width=".6*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition />
                        <RowDefinition Height="6" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Style="{DynamicResource TextBlockSubTitleBold}"
                        Text="Ftp配置"
                    />
                    <CheckBox
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="100,3,0,0"
                        VerticalAlignment="Top"
                        Content="启用"
                        IsChecked="{Binding MesParameterCopy.FtpServiceInfo.Enable}"
                    />
                    <Button
                        Grid.Column="4"
                        Grid.ColumnSpan="2"
                        Margin="0,0,60,0"
                        Padding="8,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{s:Action UploadOldDataCMD}"
                        Content="上传旧数据"
                        Style="{StaticResource ButtonDanger}"
                    />
                    <Button
                        Grid.Column="4"
                        Grid.ColumnSpan="2"
                        Width="50"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{s:Action FtpTestCMD}"
                        Content="{DynamicResource 测试}"
                        Style="{StaticResource ButtonPrimary}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Height="30"
                        Margin="0,0,0,0"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="主机地址"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.Host}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Grid.Column="2"
                        Height="30"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="端口"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="60"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.Port}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Grid.Column="4"
                        Height="30"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="超时时间(ms)"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.UploadTimeoutMs}"
                    />
                    <hc:TextBox
                        Grid.Row="3"
                        Grid.Column="0"
                        Height="30"
                        hc:TitleElement.Title="主机目录"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.RemoteDirectory}"
                    />
                    <hc:TextBox
                        Grid.Row="3"
                        Grid.Column="2"
                        Height="30"
                        hc:TitleElement.Title="用户名"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="60"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.Name}"
                    />

                    <hc:TextBox
                        Grid.Row="3"
                        Grid.Column="4"
                        Height="30"
                        VerticalAlignment="Center"
                        hc:TitleElement.Title="密码"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        Text="{Binding MesParameterCopy.FtpServiceInfo.Password}"
                    />
                </Grid>
            </Border>
            <Border Grid.RowSpan="5" Grid.Column="2" Background="{DynamicResource RegionBrush}" CornerRadius="{DynamicResource MainCornerRadius}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Style="{DynamicResource TextBlockSubTitleBold}"
                        Text="{DynamicResource 测试接口}"
                    />
                    <hc:TextBox
                        Grid.Row="1"
                        Padding="3,0,25,0"
                        VerticalAlignment="Bottom"
                        hc:BorderElement.CornerRadius="0"
                        hc:TitleElement.Title="{DynamicResource MES接口}"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        BorderThickness="0,0,0,1"
                        IsReadOnly="True"
                        Text="{Binding InterfaceName}"
                    />
                    <hc:TextBox
                        Grid.Row="2"
                        VerticalAlignment="Bottom"
                        hc:BorderElement.CornerRadius="0"
                        hc:TitleElement.Title="UrlOrTopic"
                        hc:TitleElement.TitlePlacement="Left"
                        hc:TitleElement.TitleWidth="80"
                        BorderThickness="0,0,0,1"
                        IsReadOnly="True"
                        Text="{Binding Url}"
                    />
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <hc:TextBox
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            hc:BorderElement.CornerRadius="0"
                            hc:TitleElement.Title="Test user"
                            hc:TitleElement.TitlePlacement="Left"
                            hc:TitleElement.TitleWidth="80"
                            BorderThickness="0,0,0,1"
                            IsReadOnly="False"
                            Text="{Binding TestUser}"
                        />
                        <Button
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Command="{s:Action SendMes}"
                            Content="{DynamicResource 发送}"
                            Style="{StaticResource ButtonPrimary}"
                        />
                    </Grid>
                    <hc:TextBox
                        Grid.Row="4"
                        Grid.ColumnSpan="3"
                        Margin="0,30,0,0"
                        Padding="10"
                        VerticalContentAlignment="Top"
                        hc:TitleElement.Title="{DynamicResource 发送数据(JSON):}"
                        hc:TitleElement.TitlePlacement="Top"
                        AcceptsReturn="True"
                        Text="{Binding SendTxt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                    />
                    <hc:TextBox
                        Grid.Row="5"
                        Grid.ColumnSpan="3"
                        Margin="0,20,0,0"
                        Padding="10"
                        VerticalContentAlignment="Top"
                        hc:TitleElement.Title="{DynamicResource 返回数据:}"
                        hc:TitleElement.TitlePlacement="Top"
                        AcceptsReturn="True"
                        Text="{Binding ReceiveTxt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="Wrap"
                    />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
