<Window
    x:Class="Kinlo.GUI.View.PlcTestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PLC测试"
    Width="1000"
    Height="600"
    mc:Ignorable="d"
>
    <Grid>
        <ListView
            Grid.Row="1"
            Margin="10"
            d:ItemsSource="{d:SampleData ItemCount=5}"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource MainDisplayListViewItemStyle}"
            ItemsSource="{Binding PlcTests}"
        >
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding ServiceName}" Header="服务名称" />
                    <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding ProcessesType}" Header="工序类型" />
                    <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding DeviceCommunicationType}" Header="设备通信类型" />

                    <GridViewColumn Header="标签">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox
                                    MinWidth="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                    Text="{Binding StartCommand.Tag.Lable}"
                                    TextWrapping="Wrap"
                                />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="数据类型">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox
                                    MinWidth="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                    ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.PlcDataTypes}"
                                    SelectedValue="{Binding PlcDataType, Mode=TwoWay}"
                                />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding ReadValue}" Header="读取值" />
                    <GridViewColumn Header="写入值">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox
                                    MinWidth="80"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                    Text="{Binding WriteValue}"
                                    TextWrapping="Wrap"
                                />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="80" Header="读取">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="Read_Click" Content="读取" DataContext="{Binding .}" Style="{StaticResource ButtonInfo.Small}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="80" Header="写入">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Click="Write_Click" Content="写入" DataContext="{Binding .}" Style="{StaticResource ButtonSuccess.Small}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Window>
