<Window
   x:Class="Kinlo.GUI.View.RemoteAssistantView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   mc:Ignorable="d"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:s="https://github.com/canton7/Stylet"
   xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
   d:DataContext="{d:DesignInstance vm:RemoteAssistantViewModel}"
   Width="900"
   Height="700"
   Title="开启远程帮助"
   ResizeMode="NoResize"
   WindowStartupLocation="CenterScreen"
>
   <!-- ══════════════════════════════════════════════
         整个弹窗内容容器，宽700 高自适应
    ══════════════════════════════════════════════ -->
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <!-- 标题栏 -->
         <RowDefinition Height="Auto" />
         <!-- 平台切换 -->
         <RowDefinition Height="Auto" />
         <!-- 步骤卡片区 -->
         <RowDefinition Height="Auto" />
         <!-- 导航按钮 -->
         <RowDefinition Height="Auto" />
         <!-- 底部操作栏 -->
      </Grid.RowDefinitions>

      <!-- ── 标题栏 ── -->
      <Border Grid.Row="0" Padding="24,18,24,14" Background="{DynamicResource PrimaryBrush}" CornerRadius="0">
         <Grid>
            <StackPanel VerticalAlignment="Center">
               <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="{DynamicResource 远程助手}" />
               <!--<TextBlock
                        Margin="0,2,0,0"
                        FontSize="12"
                        Foreground="#CCFFFFFF"
                        Text="{DynamicResource 远程助手_副标题}"
                    />-->
            </StackPanel>
            <!-- 网速徽标（轻量，仅显示，不消耗额外线程） -->
            <Border
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               Background="#33FFFFFF"
               CornerRadius="4"
               Padding="10,4"
               Visibility="{Binding IsNetworkConnected, Converter={StaticResource Boolean2VisibilityConverter}}"
            >
               <StackPanel Orientation="Horizontal">
                  <TextBlock FontSize="11" Foreground="#CCFFFFFF" Text="{DynamicResource 网速标签}" />
                  <TextBlock
                     Margin="4,0,0,0"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="White"
                     Text="{Binding NetworkSpeedText}"
                  />
               </StackPanel>
            </Border>
         </Grid>
      </Border>

      <!-- ── 平台选择 Toggle ── -->
      <Border Grid.Row="1" Padding="24,12" Background="{DynamicResource RegionBrush}">
         <!-- 平台选择 Toggle -->
         <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
            <TextBlock
               Margin="0,0,12,0"
               VerticalAlignment="Center"
               FontSize="13"
               Text="{DynamicResource 选择手机类型}"
            />

            <!-- 安卓按钮 -->
            <Button
               Width="110"
               Height="32"
               Margin="0,0,6,0"
               Command="{s:Action SwitchToAndroidCMD}"
               Content="{DynamicResource 安卓手机}"
            >
               <Button.Style>
                  <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAndroid}" Value="True">
                           <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                           <Setter Property="Foreground" Value="White" />
                           <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </Button.Style>
            </Button>

            <!-- 苹果按钮 -->
            <Button Width="110" Height="32" Command="{s:Action SwitchToIosCMD}" Content="{DynamicResource 苹果手机}">
               <Button.Style>
                  <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAndroid}" Value="False">
                           <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                           <Setter Property="Foreground" Value="White" />
                           <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </Button.Style>
            </Button>
         </StackPanel>
      </Border>

      <!-- ── 步骤卡片横向滚动区 ── -->
      <Border Grid.Row="2" Margin="0" Padding="0,10" Background="{DynamicResource BackgroundBrush}">
         <!--
                使用 UniformGrid 固定显示一张卡片，通过 Margin 动画滑动
                简单实现：ItemsControl + 当前步骤索引绑定 SelectedIndex
                这里用 TabControl 无Header方案，简洁且无额外依赖
            -->
         <Grid Height="360">
            <ContentControl Content="{Binding CurrentStep}">
               <ContentControl.ContentTemplate>
                  <DataTemplate>
                     <Border
                        Margin="24,0"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MainCornerRadius}"
                     >
                        <Grid Margin="20,16">
                           <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="280" />
                              <!-- 图片区加宽 -->
                              <ColumnDefinition Width="20" />
                              <ColumnDefinition />
                           </Grid.ColumnDefinitions>

                           <!-- 图片区 -->
                           <!--<Border
                            Grid.Column="0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            CornerRadius="6"
                            ClipToBounds="True"
                        >
                                        <Image
                                Source="{Binding ImagePath}"
                                Stretch="Uniform"
                                Margin="0"
                                RenderOptions.BitmapScalingMode="HighQuality"
                            />
                                    </Border>-->

                           <Border
                              Grid.Column="0"
                              Background="{DynamicResource SecondaryRegionBrush}"
                              CornerRadius="6"
                              ClipToBounds="True"
                           >
                              <Button
                                 Padding="0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Cursor="Hand"
                                 Command="{s:Action PreviewImageCMD}"
                                 CommandParameter="{Binding ImagePath}"
                                 Style="{StaticResource ButtonCustom}"
                              >
                                 <Image
                                    Source="{Binding ImagePath}"
                                    Stretch="Uniform"
                                    Margin="0"
                                    RenderOptions.BitmapScalingMode="HighQuality"
                                 />
                              </Button>
                           </Border>

                           <!-- 文字区 -->
                           <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                              <!-- 步骤徽标 -->
                              <Border
                                 HorizontalAlignment="Left"
                                 Background="{DynamicResource PrimaryBrush}"
                                 CornerRadius="3"
                                 Padding="10,3"
                              >
                                 <TextBlock
                                    FontSize="11"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding StepLabel}"
                                 />
                              </Border>

                              <TextBlock
                                 Margin="0,12,0,0"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 Text="{Binding Title}"
                                 TextWrapping="Wrap"
                              />

                              <Rectangle
                                 Height="1"
                                 Margin="0,10,0,10"
                                 Fill="{DynamicResource BorderBrush}"
                                 Opacity="0.5"
                              />

                              <TextBlock
                                 FontSize="13"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 LineHeight="22"
                                 Text="{Binding Description}"
                                 TextWrapping="Wrap"
                              />
                           </StackPanel>
                        </Grid>
                     </Border>
                  </DataTemplate>
               </ContentControl.ContentTemplate>
            </ContentControl>
         </Grid>
      </Border>

      <!-- ── 步骤导航（上一步 / 进度点 / 下一步） ── -->
      <Grid Grid.Row="3" Margin="24,8">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="Auto" />
         </Grid.ColumnDefinitions>

         <Button
            Grid.Column="0"
            Width="90"
            Command="{s:Action PrevStepCMD}"
            Content="{DynamicResource 上一步}"
            IsEnabled="{Binding CanGoPrev}"
            Style="{StaticResource ButtonDefault}"
         />

         <!-- 进度点 -->
         <ItemsControl
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            ItemsSource="{Binding StepDots}"
         >
            <ItemsControl.ItemsPanel>
               <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" />
               </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <Ellipse Width="{Binding Size}" Height="{Binding Size}" Margin="4,0" Fill="{Binding Fill}" />
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>

         <Button
            Grid.Column="2"
            Width="90"
            Command="{s:Action NextStepCMD}"
            Content="{DynamicResource 下一步}"
            IsEnabled="{Binding CanGoNext}"
            Style="{StaticResource ButtonPrimary}"
         />
      </Grid>

      <!-- ── 底部操作栏 ── -->
      <Border Grid.Row="4" Padding="24,14" Background="{DynamicResource RegionBrush}" CornerRadius="0,0,8,8">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition />
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="12" />
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="12" />
               <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 网络状态指示 -->
            <Border
               Grid.Column="0"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               Background="{Binding NetworkStatusBackground}"
               CornerRadius="4"
               Padding="10,5"
            >
               <TextBlock
                  FontSize="12"
                  FontWeight="SemiBold"
                  Foreground="{Binding NetworkStatusForeground}"
                  Text="{Binding NetworkStatusText}"
               />
            </Border>

            <!-- 检测网络 -->
            <Button
               Grid.Column="1"
               Width="100"
               Command="{s:Action CheckNetworkCMD}"
               Content="{Binding CheckNetworkBtnText}"
               IsEnabled="{Binding IsNotChecking}"
               Style="{StaticResource ButtonInfo}"
            />

            <!-- 分隔 -->
            <Rectangle Grid.Column="2" Width="1" Margin="0,6" Fill="{DynamicResource BorderBrush}" />
            <WrapPanel Grid.Column="3">
               <Button
                  hc:BorderElement.CornerRadius="4 0 0 4"
                  Command="{s:Action OpenRemoteCMD}"
                  CommandParameter="1"
                  kc:LanguageResource.Key="打开UU远程"
                  Style="{StaticResource ButtonSuccess}"
               />
               <Button
                  Grid.Column="3"
                  hc:BorderElement.CornerRadius="0"
                  Command="{s:Action OpenRemoteCMD}"
                  CommandParameter="2"
                  kc:LanguageResource.Key="打开ToDesk"
                  Style="{StaticResource ButtonPrimary}"
               />

               <Button
                  Grid.Column="3"
                  hc:BorderElement.CornerRadius="0 4 4 0"
                  Command="{s:Action OpenRemoteCMD}"
                  CommandParameter="3"
                  Content="{DynamicResource 打开向日葵}"
                  Style="{StaticResource ButtonSuccess}"
               />
            </WrapPanel>
            <!-- 关闭 -->
            <Button
               Grid.Column="5"
               Width="80"
               Command="{s:Action CloseCMD}"
               Content="{DynamicResource 关闭}"
               Style="{StaticResource ButtonDefault}"
            />
         </Grid>
      </Border>
   </Grid>
</Window>
