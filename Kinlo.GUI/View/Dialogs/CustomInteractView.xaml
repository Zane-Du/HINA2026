<Window
    x:Class="Kinlo.GUI.View.CustomInteractView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:vm="clr-namespace:Kinlo.GUI.View"
    Title="{Binding Title}"
    Width="600"
    d:DataContext="{d:DesignInstance vm:CustomInteractView}"
    SizeToContent="Height"
    mc:Ignorable="d"
>
    <Window.Resources>
        <GridLength x:Key="TitleWidth">90</GridLength>
    </Window.Resources>
    <StackPanel Margin="{StaticResource ControlPadding}">
        <hc:ComboBox
            Height="25"
            Margin="0,10"
            hc:TitleElement.Title="选择交互"
            hc:TitleElement.TitlePlacement="Left"
            hc:TitleElement.TitleWidth="{StaticResource TitleWidth}"
            ItemsSource="{Binding CustomInteractNames}"
            Text="{Binding CustomPlcInteractAddress.CustomInteractName}"
        />

        <hc:ComboBox
            Height="25"
            Margin="0,10"
            hc:TitleElement.Title="{DynamicResource 数量}"
            hc:TitleElement.TitlePlacement="Left"
            hc:TitleElement.TitleWidth="{StaticResource TitleWidth}"
            ItemsSource="{Binding Numbers}"
            Text="{Binding CustomPlcInteractAddress.DataLength}"
        />

        <hc:TextBox
            Height="25"
            Margin="0,10"
            hc:TitleElement.Title="{DynamicResource 取数据标签}"
            hc:TitleElement.TitlePlacement="Left"
            hc:TitleElement.TitleWidth="{StaticResource TitleWidth}"
            Text="{Binding CustomPlcInteractAddress.DataAddress.Lable}"
        />
        <hc:TextBox
            Height="25"
            Margin="0,10"
            hc:TitleElement.Title="{DynamicResource 备用数据标签}"
            hc:TitleElement.TitlePlacement="Left"
            hc:TitleElement.TitleWidth="{StaticResource TitleWidth}"
            Text="{Binding CustomPlcInteractAddress.ExtraDataAddress.Lable}"
        />

        <CheckBox
            Grid.Column="2"
            Height="22"
            Margin="0,5,0,0"
            HorizontalAlignment="Right"
            Content="{DynamicResource 启用}"
            IsChecked="{Binding CustomPlcInteractAddress.IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        />

        <Button Width="150" Margin="0,20,0,0" Command="{s:Action ConfirmCMD}" Content="{DynamicResource 确定}" Style="{StaticResource ButtonSuccess}" />
    </StackPanel>
</Window>
