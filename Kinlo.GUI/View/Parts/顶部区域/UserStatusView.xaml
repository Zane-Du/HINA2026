<UserControl
   x:Class="Kinlo.GUI.View.UserStatusView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:cvt="clr-namespace:Kinlo.Common.Converters;assembly=Kinlo.Common"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:s="https://github.com/canton7/Stylet"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
   xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
   d:DataContext="{d:DesignInstance vm:UserStatusViewModel}"
   d:DesignHeight="50"
   d:DesignWidth="380"
   mc:Ignorable="d"
>
   <UserControl.Resources>
      <cvt:LoggerInTypeToVisibilityConverter x:Key="LoggerInTypeToVisibilityConverter" />
   </UserControl.Resources>
   <Grid>
      <Grid.ColumnDefinitions>
         <ColumnDefinition Width="auto" />
         <ColumnDefinition Width="auto" />
         <ColumnDefinition Width="auto" />
         <ColumnDefinition Width="auto" />
      </Grid.ColumnDefinitions>
      <TextBlock
         Name="MyFadingText"
         Grid.Column="0"
         Margin="10,0"
         VerticalAlignment="Center"
         FontSize="20"
         FontWeight="Bold"
         Foreground="Red"
         Text="{DynamicResource 自动登陆禁用中...}"
         Visibility="{Binding UsersStatus.IsAutoLogin, Converter={StaticResource Boolean2VisibilityReConverter}}"
      >
         <TextBlock.Triggers>
            <EventTrigger RoutedEvent="TextBlock.Loaded">
               <BeginStoryboard>
                  <Storyboard>
                     <DoubleAnimation
                        AutoReverse="True"
                        RepeatBehavior="Forever"
                        Storyboard.TargetName="MyFadingText"
                        Storyboard.TargetProperty="(TextBlock.Opacity)"
                        From="1.0"
                        To="0.3"
                        Duration="0:0:0.3"
                     />
                  </Storyboard>
               </BeginStoryboard>
            </EventTrigger>
         </TextBlock.Triggers>
      </TextBlock>
      <Grid Grid.Column="1" Margin="0,0,0,0">
         <StackPanel
            Orientation="Horizontal"
            Visibility="{Binding UsersStatus.LoggedInUserType, Converter={StaticResource LoggerInTypeToVisibilityConverter}, ConverterParameter=0}"
         >
            <Button
               Foreground="{DynamicResource PrimaryBrush}"
               Margin="0,0"
               Command="{s:Action LocalLoginCMD}"
               Style="{StaticResource ButtonCustom}"
            >
               <WrapPanel>
                  <TextBlock FontFamily="/Font/#iconfont" FontSize="16" Text="&#xe60c;" />
                  <TextBlock FontSize="13" Margin="5 0 0 0" Text="{tools:ResourceBinding SelectLoginType}" />
               </WrapPanel>
            </Button>
            <ToggleButton
               IsChecked="{Binding LoginTypeIsChecked}"
               x:Name="openConfig"
               Style="{StaticResource ToggleButtonCustom}"
               Padding="0"
               VerticalAlignment="Stretch"
               Margin="3 3 0 0"
               Height="20"
               Background="Transparent"
            >
               <TextBlock
                  FontFamily="/Font/#iconfont"
                  FontSize="20"
                  VerticalAlignment="Center"
                  Margin="0 0 0 1"
                  Text="&#xe604;"
               >
                  <TextBlock.RenderTransform>
                     <RotateTransform x:Name="ArrowRotate" Angle="0" CenterX="10" CenterY="9" />
                  </TextBlock.RenderTransform>
               </TextBlock>
               <ToggleButton.Triggers>
                  <!-- Checked：旋转 180 -->
                  <EventTrigger RoutedEvent="ToggleButton.Checked">
                     <BeginStoryboard>
                        <Storyboard>
                           <DoubleAnimation
                              Storyboard.TargetName="ArrowRotate"
                              Storyboard.TargetProperty="Angle"
                              To="180"
                              Duration="0:0:0.3"
                           />
                        </Storyboard>
                     </BeginStoryboard>
                  </EventTrigger>

                  <!-- Unchecked：恢复 -->
                  <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                     <BeginStoryboard>
                        <Storyboard>
                           <DoubleAnimation
                              Storyboard.TargetName="ArrowRotate"
                              Storyboard.TargetProperty="Angle"
                              To="0"
                              Duration="0:0:0.3"
                           />
                        </Storyboard>
                     </BeginStoryboard>
                  </EventTrigger>
               </ToggleButton.Triggers>
            </ToggleButton>
            <Popup
               AllowsTransparency="True"
               PopupAnimation="Slide"
               IsOpen="{Binding ElementName=openConfig, Path=IsChecked}"
               PlacementTarget="{Binding ElementName=openConfig}"
               StaysOpen="False"
            >
               <Border
                  Margin="20"
                  Effect="{StaticResource   EffectShadow5}"
                  CornerRadius="5"
                  Background="White"
                  Padding="0"
               >
                  <ListBox
                     HorizontalContentAlignment="Center"
                     MinWidth="160"
                     SelectedItem="{Binding SelectLoginType}"
                     ItemsSource="{Binding LoginTypes}"
                  ></ListBox>
               </Border>
            </Popup>
         </StackPanel>
         <StackPanel
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Visibility="{Binding UsersStatus.LoggedInUserType, Converter={StaticResource LoggerInTypeToVisibilityConverter}, ConverterParameter=1}"
         >
            <TextBlock
               VerticalAlignment="Center"
               FontFamily="/Font/#iconfont"
               FontSize="16"
               Foreground="{DynamicResource PrimaryBrush}"
               Text="&#xe60c;"
            />
            <Button
               Margin="-2,0,6,0"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Style="{StaticResource ButtonCustom}"
            >
               <WrapPanel>
                  <TextBlock
                     Margin="8,0,0,0"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{DynamicResource PrimaryBrush}"
                     Style="{StaticResource TextBlockTitle}"
                  >
                     <Run Text="{Binding UsersStatus.LocalLoggedinUser.Account}" />
                     <Run Text="{Binding UsersStatus.LocalLoggedinUser.Role.Name, StringFormat=[{0}]}" />
                  </TextBlock>
                  <TextBlock
                     Margin="2,0,0,0"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{DynamicResource InfoBrush}"
                     Style="{StaticResource TextBlockTitle}"
                     Text="{tools:ResourceBinding UsersStatus.LoggedInUserType}"
                  />
               </WrapPanel>
            </Button>
            <Button
               Margin="0,0,0,0"
               VerticalAlignment="Center"
               Command="{s:Action LocalLogOutCMD}"
               Content="{DynamicResource 注销}"
               FontSize="12"
               Foreground="Red"
               Style="{StaticResource ButtonCustom}"
            />
         </StackPanel>
      </Grid>
   </Grid>
</UserControl>
