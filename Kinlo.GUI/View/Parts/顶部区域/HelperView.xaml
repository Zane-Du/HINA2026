<Menu
   x:Class="Kinlo.GUI.View.HelperView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   mc:Ignorable="d"
   xmlns:s="https://github.com/canton7/Stylet"
   d:DesignHeight="450"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   Style="{StaticResource  MenuBaseStyle}"
   Margin="0,0,0,0"
   Background="Transparent"
   VerticalAlignment="Center"
   WindowChrome.IsHitTestVisibleInChrome="True"
   d:DesignWidth="800"
>
   <MenuItem
      Margin="0"
      HorizontalAlignment="Stretch"
      HorizontalContentAlignment="Stretch"
      Cursor="Hand"
      WindowChrome.IsHitTestVisibleInChrome="True"
      FontFamily="/Font/#iconfont"
   >
      <MenuItem.Header>
         <WrapPanel>
            <TextBlock
               Foreground="{StaticResource PrimaryBrush}"
               FontSize="18"
               VerticalAlignment="Center"
               FontFamily="/Font/#iconfont"
               Text="&#xe640;"
            />
            <TextBlock FontSize="13" Margin="5 0 0 0" VerticalAlignment="Center" kc:LanguageResource.Key="帮助" />
         </WrapPanel>
      </MenuItem.Header>
      <MenuItem Command="{s:Action OpenRemoteAssistantCmd}" FontSize="12" Header="{DynamicResource 远程助手}">
         <MenuItem.Icon>
            <Path
               Width="14"
               Height="14"
               Stretch="Uniform"
               Fill="{DynamicResource PrimaryTextBrush}"
               Data="{StaticResource AskGeometry}"
            />
         </MenuItem.Icon>
      </MenuItem>
      <Separator Margin="-50,2,0,2" />
      <MenuItem Command="{s:Action OpenMaualCmd}" FontSize="12" Header="{DynamicResource 打开说明书}">
         <MenuItem.Icon>
            <Path
               Width="14"
               Height="14"
               Stretch="Uniform"
               Fill="{DynamicResource PrimaryTextBrush}"
               Data="{StaticResource EnlargeGeometry}"
            />
         </MenuItem.Icon>
      </MenuItem>
      <Separator Margin="-50,2,0,2" />
      <MenuItem Command="{s:Action UpdateCMD}" FontSize="12" Header="{DynamicResource 更新}">
         <MenuItem.Icon>
            <Path
               Width="14"
               Height="14"
               Stretch="Uniform"
               Fill="{DynamicResource PrimaryTextBrush}"
               Data="{StaticResource RotateLeftGeometry}"
            />
         </MenuItem.Icon>
      </MenuItem>

      <MenuItem Command="{s:Action BackupCMD}" FontSize="12" Header="{DynamicResource 备份}">
         <MenuItem.Icon>
            <Path
               Width="14"
               Height="14"
               Stretch="Uniform"
               Fill="{DynamicResource PrimaryTextBrush}"
               Data="{StaticResource SaveGeometry}"
            />
         </MenuItem.Icon>
      </MenuItem>
      <MenuItem Command="{s:Action RevertCMD}" FontSize="12" Header="{DynamicResource 还原}">
         <MenuItem.Icon>
            <Path
               Width="14"
               Height="14"
               Stretch="Uniform"
               Fill="{DynamicResource PrimaryTextBrush}"
               Data="{StaticResource DownloadGeometry}"
            />
         </MenuItem.Icon>
      </MenuItem>
      <Separator Margin="-50,2,0,2" />
      <MenuItem
         Margin="0"
         ItemsSource="{Binding OtherParameter.Languages}"
         Header="{DynamicResource 语言}"
         Cursor="Hand"
         HorizontalContentAlignment="Left"
         WindowChrome.IsHitTestVisibleInChrome="True"
      >
         <MenuItem.Icon>
            <TextBlock Text="&#xe85f;" FontFamily="/Font/#iconfont" FontSize="16" />
         </MenuItem.Icon>

         <MenuItem.ItemTemplate>
            <DataTemplate>
               <MenuItem
                  Margin="0"
                  Padding="0"
                  HorizontalContentAlignment="Left"
                  HorizontalAlignment="Left"
                  Command="{s:Action SelectedLanguageCMD}"
                  CommandParameter="{Binding}"
                  FontSize="12"
                  Header="{Binding Title}"
               ></MenuItem>
            </DataTemplate>
         </MenuItem.ItemTemplate>
      </MenuItem>
   </MenuItem>
</Menu>
