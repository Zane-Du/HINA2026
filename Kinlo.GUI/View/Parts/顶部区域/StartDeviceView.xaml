<UserControl
  x:Class="Kinlo.GUI.View.StartDeviceView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:s="https://github.com/canton7/Stylet"
  d:DesignHeight="450"
  d:DesignWidth="800"
  mc:Ignorable="d">
  <Grid>
    <Button
      Padding="0"
      BorderThickness="0"
      Command="{s:Action RunCmd}"
      DataContext="{Binding Temporary}"
      Visibility="{Binding IsLoadFun, Converter={StaticResource Boolean2VisibilityConverter}}">
      <Button.Style>
        <Style BasedOn="{StaticResource ButtonCustom}" TargetType="Button">
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="Button">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                  </Grid.ColumnDefinitions>

                  <!--  左边图标  -->
                  <Grid>
                    <Border
                      x:Name="startBorder"
                      Width="22"
                      Height="22"
                      BorderBrush="{DynamicResource PrimaryBrush}"
                      BorderThickness="0"
                      CornerRadius="25"
                      Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityConverter}}">
                      <Border.RenderTransform>
                        <RotateTransform Angle="0" CenterX="11" CenterY="11" />
                      </Border.RenderTransform>
                      <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="/Font/#iconfont"
                        FontSize="22"
                        Foreground="{DynamicResource PrimaryBrush}"
                        Text="&#xe618;" />
                    </Border>

                    <Border
                      Width="22"
                      Height="22"
                      BorderBrush="{DynamicResource DangerBrush}"
                      BorderThickness="0"
                      CornerRadius="20"
                      Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityReConverter}}">
                      <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="/Font/#iconfont"
                        FontSize="22"
                        Foreground="{DynamicResource DangerBrush}"
                        Text="&#xe800;" />
                    </Border>
                  </Grid>

                  <!--  右边文字  -->
                  <Grid Grid.Column="1">
                    <TextBlock
                      x:Name="msgText"
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="12"
                      Foreground="{DynamicResource PrimaryBrush}"
                      Text="{DynamicResource 运行中...}"
                      Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityConverter}}" />
                    <TextBlock
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"
                      FontSize="12"
                      Foreground="{DynamicResource DangerBrush}"
                      Text="{DynamicResource 已停止...}"
                      Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityReConverter}}" />
                  </Grid>
                </Grid>

                <ControlTemplate.Triggers>
                  <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <DataTrigger.EnterActions>
                      <BeginStoryboard x:Name="rotateBegin">
                        <Storyboard>
                          <DoubleAnimation
                            RepeatBehavior="Forever"
                            Storyboard.TargetName="startBorder"
                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                            To="360"
                            Duration="0:0:0.6" />
                        </Storyboard>
                      </BeginStoryboard>

                      <BeginStoryboard x:Name="opacityBegin">
                        <Storyboard>
                          <DoubleAnimationUsingKeyFrames
                            RepeatBehavior="Forever"
                            Storyboard.TargetName="msgText"
                            Storyboard.TargetProperty="(TextBlock.Opacity)">
                            <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0.3" />
                            <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1" />
                          </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                      </BeginStoryboard>
                    </DataTrigger.EnterActions>

                    <DataTrigger.ExitActions>
                      <StopStoryboard BeginStoryboardName="rotateBegin" />
                      <StopStoryboard BeginStoryboardName="opacityBegin" />
                    </DataTrigger.ExitActions>
                  </DataTrigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Button.Style>
    </Button>

    <TextBlock
      VerticalAlignment="Center"
      kc:LanguageResource.Key="加载中..."
      FontSize="18"
      Foreground="Red"
      Visibility="{Binding Temporary.IsLoadFun, Converter={StaticResource Boolean2VisibilityReConverter}}">
      <TextBlock.Triggers>
        <!--  当窗口加载时触发动画  -->
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
          <BeginStoryboard>
            <Storyboard>
              <!--  对 Opacity 属性应用关键帧动画  -->
              <DoubleAnimationUsingKeyFrames
                RepeatBehavior="Forever"
                Storyboard.TargetProperty="Opacity"
                Duration="0:0:1">
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0.3" />
                <EasingDoubleKeyFrame KeyTime="0:0:1" Value="1" />
              </DoubleAnimationUsingKeyFrames>
            </Storyboard>
          </BeginStoryboard>
        </EventTrigger>
      </TextBlock.Triggers>
    </TextBlock>
  </Grid>
</UserControl>
