<UserControl
   x:Class="Kinlo.GUI.View.Test_UnitView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:model="clr-namespace:Kinlo.GUI.DeviceTest"
   xmlns:s="https://github.com/canton7/Stylet"
   xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
   d:DataContext="{d:DesignInstance vm:Test_UnitViewModel}"
   d:DesignHeight="600"
   d:DesignWidth="900"
   hc:Dialog.Token="DialogQuery"
   mc:Ignorable="d"
>
   <Grid>
      <ScrollViewer VerticalScrollBarVisibility="Auto">
         <StackPanel Margin="20">
            <!--  ══ 设备信息头 ══  -->
            <!--  ══ 设备信息头 ══  -->
            <Border
               Margin="0,0,0,16"
               Padding="16,12"
               Background="{DynamicResource RegionBrush}"
               BorderBrush="{DynamicResource BorderBrush}"
               BorderThickness="1"
               CornerRadius="{DynamicResource MainCornerRadius}"
            >
               <!--  ══ 设备信息头 ══  -->
               <!--  ══ 设备信息头 ══  -->
               <Border
                  Margin="0,0,0,16"
                  Background="{DynamicResource RegionBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1"
                  ClipToBounds="True"
                  CornerRadius="{DynamicResource MainCornerRadius}"
               >
                  <Grid>
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8" />
                        <!--  左侧彩色竖条  -->
                        <ColumnDefinition />
                     </Grid.ColumnDefinitions>

                     <!--  左侧主色竖条装饰  -->
                     <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" />

                     <!--  主体内容  -->
                     <Grid Grid.Column="1" Margin="16,14,16,14">
                        <Grid.RowDefinitions>
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="10" />
                           <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  第一行：工序名称（大字突出）  -->
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" Orientation="Horizontal">
                           <TextBlock
                              VerticalAlignment="Center"
                              FontSize="20"
                              FontWeight="Bold"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              Text="{Binding Device.ProcessesType}"
                           />
                           <!--  在线状态徽标  -->
                           <Border Margin="12,0,0,0" Padding="8,2" VerticalAlignment="Center" CornerRadius="10">
                              <Border.Style>
                                 <Style TargetType="Border">
                                    <Setter Property="Background" Value="#F0F0F0" />
                                    <Style.Triggers>
                                       <DataTrigger Binding="{Binding Device.IsOnline}" Value="True">
                                          <Setter Property="Background" Value="#DCFCE7" />
                                       </DataTrigger>
                                    </Style.Triggers>
                                 </Style>
                              </Border.Style>
                              <StackPanel Orientation="Horizontal">
                                 <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                       <Style TargetType="Ellipse">
                                          <Setter Property="Fill" Value="#AAAAAA" />
                                          <Style.Triggers>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="1">
                                                <Setter Property="Fill" Value="#16A34A" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="2">
                                                <Setter Property="Fill" Value="#EF4444" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="3">
                                                <Setter Property="Fill" Value="#F59E0B" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="99">
                                                <Setter Property="Fill" Value="#AAAAAA" />
                                             </DataTrigger>
                                          </Style.Triggers>
                                       </Style>
                                    </Ellipse.Style>
                                 </Ellipse>

                                 <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                       <Style TargetType="TextBlock">
                                          <Setter Property="Text" Value="未知" />
                                          <Setter Property="Foreground" Value="#888888" />
                                          <Style.Triggers>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="1">
                                                <Setter Property="Text" Value="在线" />
                                                <Setter Property="Foreground" Value="#16A34A" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="2">
                                                <Setter Property="Text" Value="无法连接" />
                                                <Setter Property="Foreground" Value="#EF4444" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="3">
                                                <Setter Property="Text" Value="无有效数据" />
                                                <Setter Property="Foreground" Value="#F59E0B" />
                                             </DataTrigger>
                                             <DataTrigger Binding="{Binding Device.IsOnline}" Value="99">
                                                <Setter Property="Text" Value="未启用" />
                                                <Setter Property="Foreground" Value="#888888" />
                                             </DataTrigger>
                                          </Style.Triggers>
                                       </Style>
                                    </TextBlock.Style>
                                 </TextBlock>
                              </StackPanel>
                           </Border>
                        </StackPanel>

                        <!--  第二行：详细信息小字  -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                           <!--  序号  -->
                           <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                              <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Text="序号" />
                              <Border Margin="6,0,0,0" Padding="7,1" Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="3">
                                 <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding Device.Index}" />
                              </Border>
                           </StackPanel>

                           <!--  通讯类型  -->
                           <StackPanel Margin="0,0,16,0" Orientation="Horizontal">
                              <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Text="通讯" />
                              <Border Margin="6,0,0,0" Padding="7,1" Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="3">
                                 <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding Device.Communication}" />
                              </Border>
                           </StackPanel>

                           <!--  IP/COM  -->
                           <StackPanel Orientation="Horizontal">
                              <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" Text="地址" />
                              <Border Margin="6,0,0,0" Padding="7,1" Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="3">
                                 <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding Device.IPCOM}" />
                              </Border>

                              <Border Margin="6,0,0,0" Padding="7,1" Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="3">
                                 <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding Device.Port}" />
                              </Border>
                           </StackPanel>
                        </StackPanel>
                     </Grid>
                  </Grid>
               </Border>
            </Border>

            <!--  ══ 动态功能分组 ══  -->
            <ItemsControl ItemsSource="{Binding ActionGroups}">
               <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type model:DeviceActionGroup}">
                     <Border
                        Margin="0,0,0,12"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource MainCornerRadius}"
                     >
                        <StackPanel>
                           <!--  分组标题栏  -->
                           <Border Padding="16,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                              <TextBlock
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 Text="{Binding GroupName}"
                              />
                           </Border>

                           <!--  动作列表  -->
                           <ItemsControl Margin="12,12,12,4" ItemsSource="{Binding Actions}">
                              <ItemsControl.ItemsPanel>
                                 <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                 </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                 <DataTemplate DataType="{x:Type model:DeviceActionItem}">
                                    <Border MinWidth="200" Margin="0,0,12,12">
                                       <StackPanel>
                                          <!--  Write 类型：输入框  -->
                                          <Grid
                                             Margin="0,0,0,6"
                                             Visibility="{Binding NeedsInput, Converter={StaticResource Boolean2VisibilityConverter}}"
                                          >
                                             <hc:TextBox
                                                hc:InfoElement.Placeholder="{Binding Placeholder}"
                                                hc:TitleElement.Title="{Binding Label}"
                                                hc:TitleElement.TitlePlacement="Top"
                                                Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}"
                                             />
                                          </Grid>

                                          <!--  执行按钮  -->
                                          <Button
                                             Height="34"
                                             Padding="14,0"
                                             HorizontalAlignment="Stretch"
                                             Command="{Binding RunCommand}"
                                             IsEnabled="{Binding CanRun}"
                                          >
                                             <!--  ✅ 按钮样式根据 ActionStyle 枚举切换  -->
                                             <Button.Style>
                                                <Style BasedOn="{StaticResource ButtonPrimary}" TargetType="Button">
                                                   <Style.Triggers>
                                                      <DataTrigger Binding="{Binding ActionStyle}" Value="Info">
                                                         <Setter Property="Background" Value="{DynamicResource InfoBrush}" />
                                                         <Setter Property="BorderBrush" Value="{DynamicResource InfoBrush}" />
                                                      </DataTrigger>
                                                      <DataTrigger Binding="{Binding ActionStyle}" Value="Success">
                                                         <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                         <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                      </DataTrigger>
                                                      <DataTrigger Binding="{Binding ActionStyle}" Value="Warning">
                                                         <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                         <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                                      </DataTrigger>
                                                      <DataTrigger Binding="{Binding ActionStyle}" Value="Danger">
                                                         <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
                                                         <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                                                      </DataTrigger>
                                                   </Style.Triggers>
                                                </Style>
                                             </Button.Style>
                                             <Grid>
                                                <!--  正常状态  -->
                                                <StackPanel
                                                   HorizontalAlignment="Center"
                                                   Orientation="Horizontal"
                                                   Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityReConverter}}"
                                                >
                                                   <!--  ✅ 用 HasIcon + DataTrigger 替换 String2VisibilityConverter  -->
                                                   <TextBlock Margin="0,0,6,0" VerticalAlignment="Center" FontSize="14" Text="{Binding Icon}">
                                                      <TextBlock.Style>
                                                         <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                               <DataTrigger Binding="{Binding HasIcon}" Value="True">
                                                                  <Setter Property="Visibility" Value="Visible" />
                                                               </DataTrigger>
                                                            </Style.Triggers>
                                                         </Style>
                                                      </TextBlock.Style>
                                                   </TextBlock>
                                                   <TextBlock VerticalAlignment="Center" FontSize="13" Text="{Binding Label}" />
                                                </StackPanel>
                                                <!--  执行中  -->
                                                <StackPanel
                                                   HorizontalAlignment="Center"
                                                   Orientation="Horizontal"
                                                   Visibility="{Binding IsRunning, Converter={StaticResource Boolean2VisibilityConverter}}"
                                                >
                                                   <hc:LoadingCircle Width="14" Height="14" Margin="0,0,6,0" />
                                                   <TextBlock VerticalAlignment="Center" FontSize="12" Text="执行中..." />
                                                </StackPanel>
                                             </Grid>
                                          </Button>

                                          <!--<Border
                                                            Margin="0,6,0,0"
                                                            Padding="10,7"
                                                            CornerRadius="4"
                                                            Visibility="{Binding HasResult,
                                                                Converter={StaticResource Boolean2VisibilityConverter}}"
                                                        >
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#F0FFF4" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                            <Setter Property="Background" Value="#FFF0F0" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <TextBox
                                                            Text="{Binding Result, Mode=OneWay}"
                                                            FontSize="12"
                                                            FontFamily="Consolas"
                                                            IsReadOnly="True"
                                                            BorderThickness="0"
                                                            Background="Transparent"
                                                            TextWrapping="Wrap"
                                                            MaxHeight="100"
                                                            VerticalScrollBarVisibility="Auto"
                                                            Cursor="IBeam"
        >
                                                                <TextBox.Style>
                                                                    <Style TargetType="TextBox">
                                                                        <Setter Property="Foreground" Value="#1A8544" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                                <Setter Property="Foreground" Value="#C02121" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBox.Style>
                                                            </TextBox>
                                                        </Border>-->
                                       </StackPanel>
                                    </Border>
                                 </DataTemplate>
                              </ItemsControl.ItemTemplate>
                           </ItemsControl>
                        </StackPanel>
                     </Border>
                  </DataTemplate>
               </ItemsControl.ItemTemplate>
            </ItemsControl>
         </StackPanel>
      </ScrollViewer>

      <!--  ══ 遮罩层 ══  -->
      <Border Background="#66000000" Visibility="{Binding IsResultPanelOpen, Converter={StaticResource Boolean2VisibilityConverter}}">
         <Border.InputBindings>
            <MouseBinding Command="{s:Action CloseResultPanelCMD}" MouseAction="LeftClick" />
         </Border.InputBindings>
      </Border>

      <!--  ══ 侧边结果面板 ══  -->
      <Border
         Width="420"
         HorizontalAlignment="Right"
         VerticalAlignment="Stretch"
         Background="{DynamicResource RegionBrush}"
         BorderBrush="{DynamicResource BorderBrush}"
         BorderThickness="1,0,0,0"
         Visibility="{Binding IsResultPanelOpen, Converter={StaticResource Boolean2VisibilityConverter}}"
      >
         <Grid>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto" />
               <!--  标题栏  -->
               <RowDefinition Height="*" />
               <!--  结果内容  -->
               <RowDefinition Height="Auto" />
               <!--  底部操作  -->
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Border Grid.Row="0" Padding="20,14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
               <Grid>
                  <StackPanel VerticalAlignment="Center">
                     <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding PanelLabel}" />
                     <!--  成功/失败状态  -->
                     <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                           <Ellipse.Style>
                              <Style TargetType="Ellipse">
                                 <Setter Property="Fill" Value="#22C55E" />
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding PanelIsSuccess}" Value="False">
                                       <Setter Property="Fill" Value="#EF4444" />
                                    </DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12">
                           <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                 <Setter Property="Text" Value="执行成功" />
                                 <Setter Property="Foreground" Value="#16A34A" />
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding PanelIsSuccess}" Value="False">
                                       <Setter Property="Text" Value="执行失败" />
                                       <Setter Property="Foreground" Value="#DC2626" />
                                    </DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </TextBlock.Style>
                        </TextBlock>
                     </StackPanel>
                  </StackPanel>

                  <!--  关闭按钮  -->
                  <Button
                     Width="32"
                     Height="32"
                     Padding="0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Command="{s:Action CloseResultPanelCMD}"
                     Content="✕"
                     FontSize="14"
                     Style="{StaticResource ButtonDefault}"
                  />
               </Grid>
            </Border>

            <!--  结果内容区  -->
            <Border Grid.Row="1" Margin="16" Padding="14" CornerRadius="{DynamicResource MainCornerRadius}">
               <Border.Style>
                  <Style TargetType="Border">
                     <Setter Property="Background" Value="#F0FFF4" />
                     <Setter Property="BorderBrush" Value="#BBF7D0" />
                     <Setter Property="BorderThickness" Value="1" />
                     <Style.Triggers>
                        <DataTrigger Binding="{Binding PanelIsSuccess}" Value="False">
                           <Setter Property="Background" Value="#FFF0F0" />
                           <Setter Property="BorderBrush" Value="#FECACA" />
                        </DataTrigger>
                     </Style.Triggers>
                  </Style>
               </Border.Style>
               <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                  <TextBox
                     Background="Transparent"
                     BorderThickness="0"
                     Cursor="IBeam"
                     FontFamily="Consolas"
                     FontSize="13"
                     IsReadOnly="True"
                     Text="{Binding PanelResult, Mode=OneWay}"
                     TextWrapping="Wrap"
                  >
                     <TextBox.Style>
                        <Style TargetType="TextBox">
                           <Setter Property="Foreground" Value="#166534" />
                           <Style.Triggers>
                              <DataTrigger Binding="{Binding PanelIsSuccess}" Value="False">
                                 <Setter Property="Foreground" Value="#991B1B" />
                              </DataTrigger>
                           </Style.Triggers>
                        </Style>
                     </TextBox.Style>
                  </TextBox>
               </ScrollViewer>
            </Border>

            <!--  底部操作  -->
            <Border Grid.Row="2" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
               <Grid>
                  <!--  字符数  -->
                  <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                     <Run Text="{Binding PanelResult.Length, Mode=OneWay}" />
                     <Run Text=" 字符" />
                  </TextBlock>

                  <!--  复制 + 关闭  -->
                  <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                     <Button
                        Width="80"
                        Height="32"
                        Margin="0,0,8,0"
                        Command="{s:Action CopyPanelResultCMD}"
                        Content="复制全部"
                        FontSize="12"
                        Style="{StaticResource ButtonDefault}"
                     />
                     <Button
                        Width="60"
                        Height="32"
                        Command="{s:Action CloseResultPanelCMD}"
                        Content="关闭"
                        FontSize="12"
                        Style="{StaticResource ButtonPrimary}"
                     />
                  </StackPanel>
               </Grid>
            </Border>
         </Grid>
      </Border>
   </Grid>
</UserControl>
