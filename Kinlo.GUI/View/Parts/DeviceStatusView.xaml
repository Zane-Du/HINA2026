        <Grid Grid.Column="1" Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,0,0" VerticalAlignment="Center" kc:LanguageResource.Key="仪器仪表状态" />
                <Rectangle Width="15" Height="15" Margin="20,0,4,0" VerticalAlignment="Center" Fill="Lime" RadiusX="4" RadiusY="4" Stroke="Gray" />
                <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="在线" />
                <Rectangle Width="15" Height="15" Margin="12,0,4,0" VerticalAlignment="Center" Fill="Red" RadiusX="4" RadiusY="4" Stroke="Gray" />
                <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="掉线" />
                <Rectangle Width="15" Height="15" Margin="12,0,4,0" VerticalAlignment="Center" Fill="White" RadiusX="4" RadiusY="4" Stroke="Gray" />
                <TextBlock VerticalAlignment="Center" kc:LanguageResource.Key="未启用" />
            </StackPanel>
            <ItemsControl
                Grid.Row="1"
                Margin="0"
                Padding="0"
                VerticalAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding Devices.DeviceList}"
            >
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding Devices.DeviceList.Count}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Border
                                Name="border"
                                MinWidth="8"
                                Margin="1"
                                Padding="0"
                                VerticalAlignment="Stretch"
                                Background="{Binding IsOnline, Converter={StaticResource OnlineToBrushConverter}}"
                                CornerRadius="3"
                            >
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                    <!--<TextBlock kc:LanguageResource.Key="{Binding ProcessesType}" Foreground="White" />
                                    <TextBlock Foreground="White" Text="{Binding Index}" />-->
                                </StackPanel>
                            </Border>
                            <Popup
                                AllowsTransparency="True"
                                IsOpen="{Binding ElementName=border, Mode=OneWay, Path=IsMouseOver}"
                                Placement="Top"
                                VerticalOffset="-20"
                            >
                                <Border
                                    Margin="10"
                                    Padding="10"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Effect="{StaticResource EffectShadow2}"
                                >
                                    <StackPanel>
                                        <WrapPanel>
                                            <TextBlock kc:LanguageResource.Key="{Binding ProcessesType}" />
                                            <TextBlock Text="{Binding Index}" />
                                        </WrapPanel>
                                        <TextBlock Margin="0,5,0,0" Text="{Binding IPCOM}" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
