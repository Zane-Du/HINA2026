<Border
  x:Class="Kinlo.GUI.View.DisplayDashboardPanelView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:cvt="clr-namespace:Kinlo.Common.Converters;assembly=Kinlo.Common"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:hc="https://handyorg.github.io/handycontrol"
  xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
  xmlns:local="clr-namespace:Kinlo.GUI.View"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
  Padding="0,0"
  HorizontalAlignment="Stretch"
  VerticalAlignment="Stretch"
  d:DesignHeight="450"
  d:DesignWidth="800"
  Background="{DynamicResource RegionBrush}"
  CornerRadius="{DynamicResource MainCornerRadius}"
  mc:Ignorable="d">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition />
      <ColumnDefinition Width="60" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid Margin="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition Width="120" />
      </Grid.ColumnDefinitions>
      <TextBlock
        Margin="0,0,0,5"
        VerticalAlignment="Top"
        FontSize="14"
        Foreground="{StaticResource PrimaryBrush}"
        Text="{DynamicResource 流量计}" />
      <StackPanel
        Grid.Column="0"
        Margin="0,20,20,0"
        HorizontalAlignment="Right"
        VerticalAlignment="Center">
        <TextBlock Margin="0,5">
          <Run Text="{DynamicResource 瞬时流量}" />
          <Run Text=":" />
          <Run Text="{Binding Temporary.HDK_LDZ_DN50.瞬时流量, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
          <Run Text="{Binding Temporary.HDK_LDZ_DN50.瞬时流量单位}" />
        </TextBlock>

        <TextBlock Margin="0,5">
          <Run Text="{DynamicResource 总量}" />
          <Run Text=":" />
          <Run Text="{Binding Temporary.HDK_LDZ_DN50.总量, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
          <Run Text="{Binding Temporary.HDK_LDZ_DN50.总量单位}" />
        </TextBlock>
      </StackPanel>
      <kc:MinimalGauge
        Grid.Column="1"
        Width="90"
        Height="90"
        Margin="0,0,0,0"
        HorizontalAlignment="Center"
        FontSize="28"
        Maximum="100"
        Minimum="0"
        NeedleColor="#16E962"
        ProgressWidth="13"
        UnitText="{Binding Temporary.HDK_LDZ_DN50.瞬时流量单位}"
        Value="{Binding Temporary.HDK_LDZ_DN50.瞬时流量, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
        <kc:MinimalGauge.ProgressBrush>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#16E962" />
            <GradientStop Offset="0.5" Color="#16E962" />
            <GradientStop Offset="1" Color="#456CF5" />
          </LinearGradientBrush>
        </kc:MinimalGauge.ProgressBrush>
      </kc:MinimalGauge>
      <TextBlock
        Grid.Column="1"
        Margin="10,0,0,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        Text="{DynamicResource 流量百分比}" />
    </Grid>

    <kc:MinimalGauge
      Grid.Column="2"
      Width="90"
      Height="90"
      Margin="20"
      HorizontalAlignment="Left"
      FontSize="28"
      NeedleColor="#ED3E24"
      ProgressWidth="13"
      Value="{Binding Value1}">
      <kc:MinimalGauge.ProgressBrush>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0" Color="#ED3E24" />
          <GradientStop Offset="0.5" Color="#F78742" />
          <GradientStop Offset="1" Color="#F7AB1B" />
        </LinearGradientBrush>
      </kc:MinimalGauge.ProgressBrush>
    </kc:MinimalGauge>
    <!--<kc:MinimalGauge
            Grid.Column="2"
            Width="90"
            Height="90"
            FontSize="28"
            NeedleColor="#CC06FB"
            ProgressWidth="13"
            Value="{Binding Value2}">
            <kc:MinimalGauge.ProgressBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#CC06FB" />
                    <GradientStop Offset="0.5" Color="#9E32F7" />
                    <GradientStop Offset="1" Color="#2895FF" />
                </LinearGradientBrush>
            </kc:MinimalGauge.ProgressBrush>
        </kc:MinimalGauge>-->
    <!--<kc:MinimalGauge
            Width="90"
            Height="90"
            FontSize="28"
            NeedleColor="#3C83FF"
            ProgressWidth="13"
            Value="{Binding Value3}">
            <kc:MinimalGauge.ProgressBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#3C83FF" />
                    <GradientStop Offset="0.5" Color="#4C99F8" />
                    <GradientStop Offset="1" Color="#24C8F5" />
                </LinearGradientBrush>
            </kc:MinimalGauge.ProgressBrush>
        </kc:MinimalGauge>-->
    <Rectangle
      Grid.Column="1"
      Width="1"
      HorizontalAlignment="Center"
      VerticalAlignment="Stretch"
      Fill="{DynamicResource BorderBrush}" />
  </Grid>
</Border>
