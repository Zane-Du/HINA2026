<Border
    x:Class="Kinlo.GUI.View.ElectricMeterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View.Parts"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    Padding="0"
    HorizontalAlignment="Stretch"
    d:DesignHeight="450"
    Background="{DynamicResource RegionBrush}"
    CornerRadius="{DynamicResource MainCornerRadius}"
    mc:Ignorable="d"
>
    <Grid Grid.Row="1" Margin="0,0,0,0" HorizontalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>

        <TextBlock Margin="15" VerticalAlignment="Top" FontSize="16" Foreground="{StaticResource PrimaryBrush}" Text="{DynamicResource 功耗}" />
        <StackPanel Grid.Row="2" Margin="15" HorizontalAlignment="Left">
            <TextBlock Grid.Row="1" Grid.Column="1">
                <Run Text="{DynamicResource 有功总电能}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.ImpEp, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="kWh" />
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="1">
                <Run Text="{DynamicResource 有功功率}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Pt, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="W" />
            </TextBlock>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" Margin="15" HorizontalAlignment="Left">
            <TextBlock Grid.Row="1" Grid.Column="3">
                <Run Text="{DynamicResource A相电压}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ua, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="V" />
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="3">
                <Run Text="{DynamicResource B相电压}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ub, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="V" />
            </TextBlock>
            <TextBlock Grid.Row="3" Grid.Column="3">
                <Run Text="{DynamicResource C相电压}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ub, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="V" />
            </TextBlock>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="2" Margin="15" HorizontalAlignment="Left">
            <TextBlock Grid.Row="1" Grid.Column="5">
                <Run Text="{DynamicResource A相电流}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ia, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="A" />
            </TextBlock>
            <TextBlock Grid.Row="2" Grid.Column="5">
                <Run Text="{DynamicResource B相电流}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ib, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="A" />
            </TextBlock>
            <TextBlock Grid.Row="3" Grid.Column="5">
                <Run Text="{DynamicResource C相电流}" />
                <Run Text=":" />
                <Run Text="{Binding Temporary.ZTDTSU666Result.Ic, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                <Run Text="A" />
            </TextBlock>
        </StackPanel>
        <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Fill="{DynamicResource BorderBrush}" />
        <Rectangle Grid.Row="2" Width="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" Fill="{DynamicResource BorderBrush}" />
        <Rectangle Grid.Row="2" Grid.Column="1" Width="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" Fill="{DynamicResource BorderBrush}" />
    </Grid>
</Border>
