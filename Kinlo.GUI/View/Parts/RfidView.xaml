<UserControl
    x:Class="Kinlo.GUI.View.RfidView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    d:DataContext="{d:DesignInstance vm:RfidViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
>
    <StackPanel Orientation="Vertical">
        <StackPanel Margin="0,0,0,30" Orientation="Horizontal">
            <TextBlock FontSize="18">
                <Run Text="{DynamicResource 设备：}" />
                <Run Text="{Binding Device.ProcessesType}" />
            </TextBlock>
            <TextBlock Margin="30,0,0,0" FontSize="18">
                <Run Text="{DynamicResource 序号：}" />
                <Run Text="{Binding Device.Index}" />
            </TextBlock>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <hc:TextBox
                VerticalAlignment="Center"
                hc:TitleElement.Title="{DynamicResource 读取值：}"
                hc:TitleElement.TitlePlacement="Left"
                Text="{Binding ReadCode}"
            />
            <Button
                Grid.Column="1"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Command="{s:Action ReadCmd}"
                Content="{DynamicResource 读取}"
                Style="{StaticResource ButtonPrimary}"
            />
        </Grid>
        <Grid Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <hc:TextBox
                VerticalAlignment="Center"
                hc:TitleElement.Title="{DynamicResource 写入值：}"
                hc:TitleElement.TitlePlacement="Left"
                Text="{Binding WriteCode}"
            />
            <Button
                Grid.Column="1"
                Margin="5,0,0,0"
                VerticalAlignment="Center"
                Command="{s:Action WriteCmd}"
                Content="{DynamicResource 写入}"
                Style="{StaticResource ButtonPrimary}"
            />
        </Grid>
    </StackPanel>
</UserControl>
