<UserControl
    x:Class="Kinlo.GUI.View.EntityPropertyVisibleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cvt="clr-namespace:Kinlo.Common.Converters;assembly=Kinlo.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Kinlo.GUI.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:tools="clr-namespace:Kinlo.Common.Tools;assembly=Kinlo.Common"
    xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
    MaxWidth="1800"
    d:Content="{d:DesignInstance vm:EntityPropertyVisibleViewModel}"
    d:DesignHeight="600"
    mc:Ignorable="d"
>
    <UserControl.Resources>
        <cvt:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="40" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <!--<TextBlock
            Margin="10,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Foreground="{StaticResource InfoBrush}"
            Style="{StaticResource TextBlockSubTitle}"
            Text="选择显示列" />-->
        <TextBlock
            Margin="10,0,0,0"
            VerticalAlignment="Center"
            Foreground="{DynamicResource DangerBrush}"
            IsEnabled="True"
            Text="{DynamicResource ***复选框指定是否显示，鼠标右键选中一个或多个后按住鼠标左键拖动显示顺序***}"
            TextWrapping="Wrap"
        />
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <CheckBox
                    Margin="10,0,0,0"
                    HorizontalAlignment="Left"
                    Checked="{s:Action AllSelected}"
                    Content="{DynamicResource 反选}"
                    Unchecked="{s:Action AllSelected}"
                />

                <ToggleButton
                    Width="100"
                    Margin="0,0,110,0"
                    HorizontalAlignment="Right"
                    Command="{s:Action ResetCmd}"
                    Content="{DynamicResource 重置}"
                    IsChecked="{Binding IsEntityPropertyVisible}"
                    Style="{StaticResource ToggleButtonDanger}"
                />
                <ToggleButton
                    Width="100"
                    HorizontalAlignment="Right"
                    Command="{s:Action SaveProperty}"
                    Content="{DynamicResource 保存}"
                    IsChecked="{Binding IsEntityPropertyVisible}"
                    Style="{StaticResource ToggleButtonSuccess}"
                />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" Height="360" Margin="0,20,0,0" AllowDrop="True" HorizontalScrollBarVisibility="Auto">
            <ItemsControl Margin="0" Padding="0" BorderThickness="0" ItemsSource="{Binding DisplayData.PropertyBindings}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Height="360" Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="25,5"
                            Padding="3"
                            Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"
                            CornerRadius="15"
                            DragDrop.Drop="{s:Action TextBlock_Drop}"
                            MouseLeftButtonDown="{s:Action Border_MouseLeftButtonDown}"
                            MouseRightButtonDown="{s:Action TextBlock_MouseLeftButtonDown}"
                        >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto" MinWidth="100" />
                                    <ColumnDefinition Width="auto" />
                                </Grid.ColumnDefinitions>
                                <!--<CheckBox
                                Grid.Column="1"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                IsChecked="{Binding IsSelected}"
                                Visibility="{Binding Source={x:Reference Name=adjustTBut}, Path=IsChecked, Converter={StaticResource Boolean2VisibilityConverter}}" />-->

                                <CheckBox
                                    Grid.Column="0"
                                    Margin="10,5"
                                    HorizontalAlignment="Left"
                                    Content="{tools:ResourceBinding Description}"
                                    IsChecked="{Binding IsVisible}"
                                />

                                <!--<CheckBox
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    HorizontalAlignment="Left"
                                    Content="{DynamicResource other_Export}"
                                    IsChecked="{Binding IsExport}"
                                    Visibility="{Binding Source={x:Reference Name=adjustTBut}, Path=IsChecked, Converter={StaticResource Boolean2VisibilityReConverter}}" />-->

                                <!--<TextBlock
                                    Grid.Column="2"
                                    Margin="0,3"
                                    VerticalAlignment="Center"
                                    Text="{tools:ResourceBinding Description}" />-->
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
