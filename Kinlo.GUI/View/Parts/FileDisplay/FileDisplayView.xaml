<UserControl
   x:Class="Kinlo.GUI.View.FileDisplayView"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
   xmlns:local="clr-namespace:Kinlo.GUI.View"
   xmlns:hc="https://handyorg.github.io/handycontrol"
   xmlns:kc="clr-namespace:KinloControls;assembly=KinloControls"
   xmlns:s="https://github.com/canton7/Stylet"
   xmlns:vm="clr-namespace:Kinlo.GUI.ViewModel"
   d:DataContext="{d:DesignInstance vm:FileDisplayViewModel}"
   mc:Ignorable="d"
   d:DesignHeight="450"
   d:DesignWidth="800"
>
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="auto" />
         <RowDefinition />
         <RowDefinition Height="auto" />
      </Grid.RowDefinitions>
      <Grid Margin="20 16 20 0">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
         </Grid.ColumnDefinitions>
         <Button Command="{s:Action BackCmd}" CommandParameter="{Binding .}" Padding="5 0 10 0">
            <WrapPanel>
               <TextBlock Margin="0 0 5 0" FontSize="16" FontFamily="/Font/#iconfont" Text="&#xe63d;" />
               <TextBlock kc:LanguageResource.Key="返回" />
            </WrapPanel>
         </Button>
         <Button Grid.Column="1" Margin="5 0" Command="{s:Action RefreshCmd}" CommandParameter="{Binding .}" Padding="5 0 10 0">
            <WrapPanel>
               <TextBlock Margin="2 0 6 0" FontSize="13" FontFamily="/Font/#iconfont" Text="&#xe638;" />
               <TextBlock kc:LanguageResource.Key="刷新" />
            </WrapPanel>
         </Button>
         <TextBox
            FontWeight="Black"
            FontSize="15"
            Foreground="{StaticResource PrimaryBrush}"
            IsReadOnly="True"
            Grid.Column="2"
            VerticalAlignment="Center"
            Text="{Binding CurrentFileNode.DisplayPaht}"
         />
      </Grid>
      <hc:ScrollViewer Grid.Row="1">
         <ItemsControl ItemsSource="{Binding Files}" x:Name="FileGrid" Margin="10">
            <ItemsControl.ItemsPanel>
               <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal" ItemWidth="96" />
               </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <Border x:Name="ItemBorder" Padding="5" CornerRadius="5" Margin="3" MouseLeftButtonUp="{s:Action FileItem_Click}">
                     <Grid HorizontalAlignment="Center" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                           <RowDefinition Height="46" />
                           <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Image
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Source="{Binding IconSource}"
                           Width="32"
                           Height="32"
                           Margin="0,0,0,0"
                        />
                        <TextBlock
                           Grid.Row="1"
                           Text="{Binding Name}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Stretch"
                           Foreground="#333"
                           FontSize="12"
                           Margin="0,2,0,0"
                           LineHeight="16"
                           LineStackingStrategy="BlockLineHeight"
                        />
                     </Grid>

                     <!-- 鼠标悬停变色 -->
                     <Border.Style>
                        <Style TargetType="Border">
                           <Setter Property="Background" Value="Transparent" />
                           <Style.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                 <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
                                 <!-- 浅灰色背景 -->
                              </Trigger>
                           </Style.Triggers>
                        </Style>
                     </Border.Style>
                  </Border>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>
      </hc:ScrollViewer>

      <!--   Grid 负责拦截全区域的拖拽事件 -->
      <Button
         HorizontalAlignment="Stretch"
         Margin="0"
         Height="80"
         Grid.Row="2"
         AllowDrop="True"
         Command="{s:Action UploadCmd}"
         BorderThickness="0 1 0 0"
         FontSize="40"
         Content="点击或拖拽文件至此处上传"
         hc:BorderElement.CornerRadius="0 0 10 10"
         Drop="{s:Action FileButton_Drop}"
         DragOver="{s:Action FileButton_DragOver}"
      >
         <Button.Style>
            <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
               <Setter Property="Foreground" Value="Gray" />
               <Style.Triggers>
                  <Trigger Property="IsMouseOver" Value="True">
                     <Setter Property="Foreground" Value="White" />
                  </Trigger>
               </Style.Triggers>
            </Style>
         </Button.Style>
      </Button>
   </Grid>
</UserControl>
